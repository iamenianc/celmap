<Window x:Class="CelMap.App.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:CelMap.App"
        mc:Ignorable="d"
        Title="CelMap — Excel Column Mapper" Height="460" Width="720"
        d:DataContext="{d:DesignInstance local:MainViewModel}">
    <Window.Resources>
        <Style TargetType="Label">
            <Setter Property="Padding" Value="0,0,0,2" />
        </Style>
        <Style TargetType="TextBox">
            <Setter Property="VerticalContentAlignment" Value="Center" />
            <Setter Property="Padding" Value="4,2" />
        </Style>
        <Style TargetType="ComboBox">
            <Setter Property="Padding" Value="4,2" />
        </Style>
    </Window.Resources>

    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*" />
            <ColumnDefinition Width="16" />
            <ColumnDefinition Width="*" />
        </Grid.ColumnDefinitions>

        <!-- Source panel -->
        <GroupBox Grid.Row="0" Grid.Column="0" Header="Source" Padding="10">
            <StackPanel>
                <Label Content="File" />
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <TextBox Grid.Column="0" Text="{Binding SourceFilePath}" IsReadOnly="True" />
                    <Button Grid.Column="1" Content="Browse…" Margin="6,0,0,0" Padding="10,2"
                            Command="{Binding BrowseSourceCommand}" />
                </Grid>

                <Label Content="Sheet" Margin="0,8,0,0" />
                <ComboBox ItemsSource="{Binding SourceSheets}"
                          SelectedItem="{Binding SelectedSourceSheet}" />

                <Label Content="Header row" Margin="0,8,0,0" />
                <TextBox Text="{Binding SourceHeaderRow}" Width="60" HorizontalAlignment="Left" />
            </StackPanel>
        </GroupBox>

        <!-- Target panel -->
        <GroupBox Grid.Row="0" Grid.Column="2" Header="Target (template — never modified)" Padding="10">
            <StackPanel>
                <Label Content="File" />
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <TextBox Grid.Column="0" Text="{Binding TargetFilePath}" IsReadOnly="True" />
                    <Button Grid.Column="1" Content="Browse…" Margin="6,0,0,0" Padding="10,2"
                            Command="{Binding BrowseTargetCommand}" />
                </Grid>

                <Label Content="Sheet" Margin="0,8,0,0" />
                <ComboBox ItemsSource="{Binding TargetSheets}"
                          SelectedItem="{Binding SelectedTargetSheet}" />

                <Label Content="Header row" Margin="0,8,0,0" />
                <TextBox Text="{Binding TargetHeaderRow}" Width="60" HorizontalAlignment="Left" />
            </StackPanel>
        </GroupBox>

        <!-- Options -->
        <GroupBox Grid.Row="1" Grid.Column="0" Grid.ColumnSpan="3" Header="Options"
                  Margin="0,12,0,0" Padding="10">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="200" />
                    <ColumnDefinition Width="40" />
                    <ColumnDefinition Width="24" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>
                <Label Grid.Column="0" Content="Confidence threshold" VerticalAlignment="Center" />
                <Slider Grid.Column="1" Minimum="0" Maximum="100" TickFrequency="5"
                        IsSnapToTickEnabled="True" VerticalAlignment="Center" Margin="8,0"
                        Value="{Binding ConfidenceThreshold}" />
                <TextBlock Grid.Column="2" Text="{Binding ConfidenceThreshold}"
                           VerticalAlignment="Center" HorizontalAlignment="Right" />
                <Label Grid.Column="4" Content="Output folder" VerticalAlignment="Center" Margin="16,0,0,0" />
                <TextBox Grid.Column="5" Text="{Binding OutputDirectory}" Margin="8,0,0,0" />
            </Grid>
        </GroupBox>

        <!-- Run -->
        <StackPanel Grid.Row="2" Grid.Column="0" Grid.ColumnSpan="3" Orientation="Horizontal"
                    HorizontalAlignment="Right" Margin="0,12,0,0">
            <Button Content="Run" MinWidth="120" Padding="12,6" FontWeight="SemiBold"
                    Command="{Binding RunCommand}" />
        </StackPanel>

        <!-- Status -->
        <Border Grid.Row="4" Grid.Column="0" Grid.ColumnSpan="3" Margin="0,12,0,0"
                Background="#F4F4F4" BorderBrush="#DDDDDD" BorderThickness="1" Padding="10">
            <TextBlock Text="{Binding Status}" TextWrapping="Wrap" VerticalAlignment="Top" />
        </Border>
    </Grid>
</Window>
