<Window x:Class="CelMap.App.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:CelMap.App"
        mc:Ignorable="d"
        Title="CelMap — Excel Column Mapper"
        Height="860" Width="1280" MinHeight="620" MinWidth="980"
        Background="{StaticResource WindowBg}"
        d:DataContext="{d:DesignInstance local:MainViewModel}">

    <!-- Undo/redo apply on the mapping screen; commands self-disable elsewhere. -->
    <Window.InputBindings>
        <KeyBinding Key="Z" Modifiers="Control" Command="{Binding UndoCommand}" />
        <KeyBinding Key="Y" Modifiers="Control" Command="{Binding RedoCommand}" />
    </Window.InputBindings>

    <Grid>
        <!-- Display density: the entire UI scales from one transform, so every element
             (fonts, paddings, grids) stays proportionate across the three tiers. -->
        <Grid.LayoutTransform>
            <ScaleTransform ScaleX="{Binding UiScale}" ScaleY="{Binding UiScale}" />
        </Grid.LayoutTransform>

        <!-- ============================================================== -->
        <!--  SCREEN 0 — Parameters Setup                                   -->
        <!-- ============================================================== -->
        <Grid Margin="14"
              Visibility="{Binding IsOnParameters, Converter={StaticResource BoolToVis}}">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <!-- Header -->
            <Grid Grid.Row="0" Margin="0,0,0,14">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <StackPanel Grid.Column="0">
                    <TextBlock Text="Insurance Member Data Parameters" FontSize="20" FontWeight="SemiBold"
                               Foreground="{StaticResource InkText}" />
                    <TextBlock Text="Specify global parameters and cover rules to auto-fill member records."
                               Foreground="{StaticResource MutedText}" FontSize="12" Margin="0,2,0,0" />
                </StackPanel>
                <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                    <TextBlock Text="Aa" FontSize="11" Foreground="{StaticResource MutedText}"
                               VerticalAlignment="Center" Margin="0,0,5,0" />
                    <ComboBox Width="110" FontSize="11" ItemsSource="{Binding DensityOptions}"
                              SelectedItem="{Binding UiDensity}"
                              ToolTip="Display size — Large for easier reading, Compact for more on screen" />
                </StackPanel>
            </Grid>

            <!-- Content Area (Scrollable) -->
            <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" MinWidth="320" />
                        <ColumnDefinition Width="20" />
                        <ColumnDefinition Width="2*" MinWidth="480" />
                    </Grid.ColumnDefinitions>

                    <!-- Left Panel: General Parameters -->
                    <Border Grid.Column="0" Style="{StaticResource Card}" VerticalAlignment="Top">
                        <StackPanel>
                            <TextBlock Text="GENERAL PARAMETERS" Style="{StaticResource SectionHeader}" />
                            
                            <StackPanel Margin="0,6,0,12">
                                <Label Content="Group ID (Required)" Target="{Binding ElementName=GroupIdInput}" />
                                <TextBox x:Name="GroupIdInput" Text="{Binding GroupIdText, UpdateSourceTrigger=PropertyChanged}" />
                                <TextBlock Text="Must be an integer representing the employer group" FontSize="11" Foreground="{StaticResource MutedText}" Margin="0,2,0,0" />
                            </StackPanel>

                            <StackPanel Margin="0,0,0,12">
                                <Label Content="Insurer ID (Required)" Target="{Binding ElementName=InsurerIdInput}" />
                                <TextBox x:Name="InsurerIdInput" Text="{Binding InsurerIdText, UpdateSourceTrigger=PropertyChanged}" />
                                <TextBlock Text="Defaults to 1" FontSize="11" Foreground="{StaticResource MutedText}" Margin="0,2,0,0" />
                            </StackPanel>

                            <StackPanel Margin="0,0,0,12">
                                <Label Content="Review Start Date" />
                                <DatePicker SelectedDate="{Binding ReviewStart}" SelectedDateFormat="Short" />
                            </StackPanel>

                            <StackPanel Margin="0,0,0,6">
                                <Label Content="Review End Date" />
                                <DatePicker SelectedDate="{Binding ReviewEnd}" SelectedDateFormat="Short" />
                                <TextBlock Text="Defaults to 1 year less 1 day from Start Date" FontSize="11" Foreground="{StaticResource MutedText}" Margin="0,2,0,0" />
                            </StackPanel>
                        </StackPanel>
                    </Border>

                    <!-- Right Panel: Cover Configuration & Category Specifics -->
                    <Border Grid.Column="2" Style="{StaticResource Card}">
                        <DockPanel>
                            <!-- Default Cover Types Section -->
                            <StackPanel DockPanel.Dock="Top" Margin="0,0,0,16">
                                <TextBlock Text="DEFAULT COVER TYPES" Style="{StaticResource SectionHeader}" />
                                <TextBlock Text="Select default covers applicable to all members (unless overridden below):" FontSize="11" Foreground="{StaticResource MutedText}" Margin="0,0,0,8" />
                                <WrapPanel Orientation="Horizontal">
                                    <CheckBox Content="GSC" IsChecked="{Binding DefaultCoverGSC}" Margin="0,0,24,6" VerticalContentAlignment="Center" />
                                    <CheckBox Content="GL" IsChecked="{Binding DefaultCoverGL}" Margin="0,0,24,6" VerticalContentAlignment="Center" />
                                    <CheckBox Content="TPD" IsChecked="{Binding DefaultCoverTPD}" Margin="0,0,24,6" VerticalContentAlignment="Center" />
                                    <CheckBox Content="Trauma" IsChecked="{Binding DefaultCoverTrauma}" Margin="0,0,24,6" VerticalContentAlignment="Center" />
                                    <CheckBox Content="GLTPD" IsChecked="{Binding DefaultCoverGLTPD}" Margin="0,0,24,6" VerticalContentAlignment="Center" />
                                </WrapPanel>
                            </StackPanel>

                            <Separator DockPanel.Dock="Top" Margin="0,0,0,12" Background="{StaticResource Hairline}" Height="1" />

                            <!-- Category Specific Cover Types Section -->
                            <DockPanel>
                                <StackPanel DockPanel.Dock="Top" Margin="0,0,0,8">
                                    <TextBlock Text="CATEGORY SPECIFIC OVERRIDES (OPTIONAL)" Style="{StaticResource SectionHeader}" />
                                    <TextBlock Text="Type in a category name (number/letter) to enable specific overrides:" FontSize="11" Foreground="{StaticResource MutedText}" />
                                </StackPanel>

                                <!-- Categories Grid -->
                                <DataGrid ItemsSource="{Binding CategoryOverrides}" AutoGenerateColumns="False" 
                                          CanUserAddRows="False" CanUserDeleteRows="False" CanUserReorderColumns="False" CanUserSortColumns="False"
                                          GridLinesVisibility="Horizontal" HeadersVisibility="Column" Background="Transparent" BorderThickness="0"
                                          RowBackground="Transparent" RowHeaderWidth="0" MaxHeight="220" VerticalAlignment="Top">
                                    <DataGrid.Resources>
                                        <Style TargetType="DataGridColumnHeader">
                                            <Setter Property="Background" Value="#F2F5FA" />
                                            <Setter Property="BorderBrush" Value="{StaticResource GridLine}" />
                                            <Setter Property="BorderThickness" Value="0,0,0,1" />
                                            <Setter Property="Padding" Value="8,6" />
                                            <Setter Property="FontWeight" Value="SemiBold" />
                                            <Setter Property="Foreground" Value="{StaticResource InkText}" />
                                        </Style>
                                        <Style x:Key="CoverHeader" TargetType="DataGridColumnHeader"
                                               BasedOn="{StaticResource {x:Type DataGridColumnHeader}}">
                                            <Setter Property="HorizontalContentAlignment" Value="Center" />
                                        </Style>
                                        <!-- Selection stays a light tint instead of the stock full-width blue bar. -->
                                        <Style TargetType="DataGridRow">
                                            <Setter Property="Background" Value="Transparent" />
                                            <Style.Triggers>
                                                <Trigger Property="IsSelected" Value="True">
                                                    <Setter Property="Background" Value="#EDF3FC" />
                                                </Trigger>
                                            </Style.Triggers>
                                        </Style>
                                        <Style TargetType="DataGridCell">
                                            <Setter Property="Padding" Value="6,4" />
                                            <Setter Property="BorderThickness" Value="0" />
                                            <Setter Property="VerticalAlignment" Value="Center" />
                                            <Setter Property="FocusVisualStyle" Value="{x:Null}" />
                                            <Style.Triggers>
                                                <Trigger Property="IsSelected" Value="True">
                                                    <Setter Property="Background" Value="Transparent" />
                                                    <Setter Property="Foreground" Value="{StaticResource InkText}" />
                                                </Trigger>
                                            </Style.Triggers>
                                        </Style>
                                        <Style x:Key="CoverCheck" TargetType="CheckBox" BasedOn="{StaticResource {x:Type CheckBox}}">
                                            <Setter Property="IsEnabled" Value="{Binding IsCategoryNameValid}" />
                                            <Setter Property="HorizontalAlignment" Value="Center" />
                                            <Setter Property="VerticalAlignment" Value="Center" />
                                        </Style>
                                    </DataGrid.Resources>
                                    <DataGrid.Columns>
                                        <DataGridTextColumn Header="Category" Binding="{Binding CategoryName, UpdateSourceTrigger=PropertyChanged}" Width="100" FontWeight="SemiBold" />
                                        <DataGridCheckBoxColumn Header="GSC" Binding="{Binding Gsc, UpdateSourceTrigger=PropertyChanged}" Width="65"
                                                                HeaderStyle="{StaticResource CoverHeader}"
                                                                ElementStyle="{StaticResource CoverCheck}" EditingElementStyle="{StaticResource CoverCheck}" />
                                        <DataGridCheckBoxColumn Header="GL" Binding="{Binding Gl, UpdateSourceTrigger=PropertyChanged}" Width="65"
                                                                HeaderStyle="{StaticResource CoverHeader}"
                                                                ElementStyle="{StaticResource CoverCheck}" EditingElementStyle="{StaticResource CoverCheck}" />
                                        <DataGridCheckBoxColumn Header="TPD" Binding="{Binding Tpd, UpdateSourceTrigger=PropertyChanged}" Width="65"
                                                                HeaderStyle="{StaticResource CoverHeader}"
                                                                ElementStyle="{StaticResource CoverCheck}" EditingElementStyle="{StaticResource CoverCheck}" />
                                        <DataGridCheckBoxColumn Header="Trauma" Binding="{Binding Trauma, UpdateSourceTrigger=PropertyChanged}" Width="65"
                                                                HeaderStyle="{StaticResource CoverHeader}"
                                                                ElementStyle="{StaticResource CoverCheck}" EditingElementStyle="{StaticResource CoverCheck}" />
                                        <DataGridCheckBoxColumn Header="GLTPD" Binding="{Binding GlTpd, UpdateSourceTrigger=PropertyChanged}" Width="65"
                                                                HeaderStyle="{StaticResource CoverHeader}"
                                                                ElementStyle="{StaticResource CoverCheck}" EditingElementStyle="{StaticResource CoverCheck}" />
                                    </DataGrid.Columns>
                                </DataGrid>
                            </DockPanel>
                        </DockPanel>
                    </Border>
                </Grid>
            </ScrollViewer>

            <!-- Bottom Control Bar -->
            <Border Grid.Row="2" BorderBrush="{StaticResource Hairline}" BorderThickness="0,1,0,0" Padding="0,12,0,0" Margin="0,12,0,0">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    
                    <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center">
                        <!-- Exactly one status shows: the blocking hint until valid, then the all-clear. -->
                        <StackPanel Orientation="Horizontal"
                                    Visibility="{Binding IsParametersValid, Converter={StaticResource BoolToVis}, ConverterParameter=invert}">
                            <TextBlock Text="⚠" Foreground="#DC2626" FontSize="12" Margin="0,0,6,0" />
                            <TextBlock Text="Enter a valid Group ID and Insurer ID to continue."
                                       Foreground="#DC2626" FontSize="12" />
                        </StackPanel>
                        <StackPanel Orientation="Horizontal"
                                    Visibility="{Binding IsParametersValid, Converter={StaticResource BoolToVis}}">
                            <TextBlock Text="✓" Foreground="#16A34A" FontWeight="Bold" FontSize="12" Margin="0,0,6,0" />
                            <TextBlock Text="Parameters are valid — ready to proceed."
                                       Foreground="#16A34A" FontSize="12" />
                        </StackPanel>
                    </StackPanel>
                    
                    <Button Grid.Column="1" Content="Continue to Setup →" Style="{StaticResource PrimaryButton}"
                            MinWidth="180" Command="{Binding ContinueToSetupCommand}" />
                </Grid>
            </Border>
        </Grid>

        <!-- ============================================================== -->
        <!--  SCREEN 1 — Setup (compact)                                    -->
        <!-- ============================================================== -->
        <!-- Compact setup screen — top-aligned, content only as tall as it needs. -->
        <Grid Margin="14" VerticalAlignment="Top"
              Visibility="{Binding IsOnSetup, Converter={StaticResource BoolToVis}}">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <Grid Grid.Row="0" Margin="0,0,0,10">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <StackPanel Grid.Column="0">
                    <TextBlock Text="Set up your mapping" FontSize="17" FontWeight="SemiBold"
                               Foreground="{StaticResource InkText}" />
                    <TextBlock Text="Drop the file you're copying FROM and the template you're copying INTO. Check the header rows, then map."
                               Foreground="{StaticResource MutedText}" FontSize="12" Margin="0,2,0,0" />
                </StackPanel>
                
                <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                    <TextBlock Text="Aa" FontSize="11" Foreground="{StaticResource MutedText}"
                               VerticalAlignment="Center" Margin="0,0,5,0" />
                    <ComboBox Width="110" FontSize="11" ItemsSource="{Binding DensityOptions}"
                              SelectedItem="{Binding UiDensity}" Margin="0,0,8,0"
                              ToolTip="Display size — Large for easier reading, Compact for more on screen" />
                    <Border Background="#F2F5FA" CornerRadius="6" BorderBrush="{StaticResource Hairline}" BorderThickness="1" Padding="8,4" Margin="0,0,8,0">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="Group: " Foreground="{StaticResource MutedText}" FontSize="11" />
                            <TextBlock Text="{Binding GroupIdText}" Foreground="{StaticResource InkText}" FontWeight="SemiBold" FontSize="11" Margin="0,0,8,0" />
                            <TextBlock Text="Insurer: " Foreground="{StaticResource MutedText}" FontSize="11" />
                            <TextBlock Text="{Binding InsurerIdText}" Foreground="{StaticResource InkText}" FontWeight="SemiBold" FontSize="11" />
                        </StackPanel>
                    </Border>
                    <Button Content="✎ Edit Parameters" Style="{StaticResource GhostButton}" Command="{Binding BackToParametersCommand}" />
                </StackPanel>
            </Grid>

            <!-- Two drop-zones side by side -->
            <Grid Grid.Row="1">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="18" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>

                <!-- SOURCE -->
                <Border Grid.Column="0" Style="{StaticResource Card}">
                    <StackPanel>
                        <TextBlock Text="SOURCE  ·  copy data FROM" Style="{StaticResource SectionHeader}" />
                        <Border x:Name="SourceDropZone" Style="{StaticResource DropZone}"
                                AllowDrop="True" Drop="SourceDropZone_Drop"
                                DragEnter="DropZone_DragEnter" DragLeave="DropZone_DragLeave"
                                MouseLeftButtonUp="SourceDropZone_Click" Cursor="Hand">
                            <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                                <TextBlock Text="{Binding SourceFileName, FallbackValue='Drop an .xlsx / .xlsm here'}"
                                           FontSize="14" FontWeight="SemiBold" TextAlignment="Center"
                                           Foreground="{StaticResource InkText}" TextTrimming="CharacterEllipsis" />
                                <TextBlock Text="or click to browse" FontSize="12" TextAlignment="Center"
                                           Foreground="{StaticResource MutedText}" Margin="0,4,0,0" />
                            </StackPanel>
                        </Border>

                        <Grid Margin="0,8,0,0">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="12" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <StackPanel Grid.Column="0">
                                <Label Content="Sheet" />
                                <ComboBox ItemsSource="{Binding SourceSheets}"
                                          SelectedItem="{Binding SelectedSourceSheet}" />
                            </StackPanel>
                            <StackPanel Grid.Column="2">
                                <Label Content="Header row (auto-detected)" />
                                <TextBox Text="{Binding SourceHeaderRow, UpdateSourceTrigger=PropertyChanged}"
                                         Width="70" HorizontalAlignment="Left" />
                            </StackPanel>
                        </Grid>

                        <TextBlock Text="First columns at that row:" FontSize="11"
                                   Foreground="{StaticResource MutedText}" Margin="0,8,0,3" />
                        <ItemsControl ItemsSource="{Binding SourceHeaderPreview}">
                            <ItemsControl.ItemsPanel>
                                <ItemsPanelTemplate><WrapPanel /></ItemsPanelTemplate>
                            </ItemsControl.ItemsPanel>
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Border Background="#EEF3FB" CornerRadius="4" Padding="8,3" Margin="0,0,6,6"
                                            BorderBrush="{StaticResource Hairline}" BorderThickness="1">
                                        <TextBlock Text="{Binding}" FontSize="12" Foreground="{StaticResource InkText}" />
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </StackPanel>
                </Border>

                <!-- TARGET -->
                <Border Grid.Column="2" Style="{StaticResource Card}">
                    <StackPanel>
                        <TextBlock Text="TARGET  ·  copy data INTO  (a copy is written, original untouched)"
                                   Style="{StaticResource SectionHeader}" TextTrimming="CharacterEllipsis" />
                        <Border x:Name="TargetDropZone" Style="{StaticResource DropZone}"
                                AllowDrop="True" Drop="TargetDropZone_Drop"
                                DragEnter="DropZone_DragEnter" DragLeave="DropZone_DragLeave"
                                MouseLeftButtonUp="TargetDropZone_Click" Cursor="Hand">
                            <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                                <TextBlock Text="{Binding TargetFileName, FallbackValue='Drop an .xlsx / .xlsm here'}"
                                           FontSize="14" FontWeight="SemiBold" TextAlignment="Center"
                                           Foreground="{StaticResource InkText}" TextTrimming="CharacterEllipsis" />
                                <TextBlock Text="or click to browse" FontSize="12" TextAlignment="Center"
                                           Foreground="{StaticResource MutedText}" Margin="0,4,0,0" />
                            </StackPanel>
                        </Border>

                        <Grid Margin="0,8,0,0">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="12" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <StackPanel Grid.Column="0">
                                <Label Content="Sheet" />
                                <ComboBox ItemsSource="{Binding TargetSheets}"
                                          SelectedItem="{Binding SelectedTargetSheet}" />
                            </StackPanel>
                            <StackPanel Grid.Column="2">
                                <Label Content="Header row (auto-detected)" />
                                <TextBox Text="{Binding TargetHeaderRow, UpdateSourceTrigger=PropertyChanged}"
                                         Width="70" HorizontalAlignment="Left" />
                            </StackPanel>
                        </Grid>

                        <TextBlock Text="First columns at that row:" FontSize="11"
                                   Foreground="{StaticResource MutedText}" Margin="0,8,0,3" />
                        <ItemsControl ItemsSource="{Binding TargetHeaderPreview}">
                            <ItemsControl.ItemsPanel>
                                <ItemsPanelTemplate><WrapPanel /></ItemsPanelTemplate>
                            </ItemsControl.ItemsPanel>
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Border Background="#EEF3FB" CornerRadius="4" Padding="8,3" Margin="0,0,6,6"
                                            BorderBrush="{StaticResource Hairline}" BorderThickness="1">
                                        <TextBlock Text="{Binding}" FontSize="12" Foreground="{StaticResource InkText}" />
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </StackPanel>
                </Border>
            </Grid>

            <!-- Output dir + Map button — grouped right so the pre-flight controls read as one unit -->
            <Grid Grid.Row="2" Margin="0,12,0,0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="320" />
                    <ColumnDefinition Width="14" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <TextBlock Grid.Column="1" Text="Output folder" VerticalAlignment="Center"
                           Foreground="{StaticResource MutedText}" FontSize="12" Margin="0,0,8,0" />
                <TextBox Grid.Column="2" Text="{Binding OutputDirectory}" VerticalAlignment="Center" />
                <Button Grid.Column="4" Content="Map →" Style="{StaticResource PrimaryButton}"
                        MinWidth="160" Command="{Binding MatchCommand}"
                        ToolTip="Auto-map the confident columns and open the mapping screen" />
            </Grid>
        </Grid>

        <!-- ============================================================== -->
        <!--  SCREEN 2 — Mapping (full window, Excel-like)                  -->
        <!-- ============================================================== -->
        <Grid Visibility="{Binding IsOnMapping, Converter={StaticResource BoolToVis}}">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />   <!-- top bar -->
                <RowDefinition Height="*" />      <!-- source grid (~1/3) -->
                <RowDefinition Height="Auto" />   <!-- splitter -->
                <RowDefinition Height="2*" />     <!-- target grid (~2/3) -->
                <RowDefinition Height="Auto" />   <!-- status -->
            </Grid.RowDefinitions>

            <!-- Slim top bar -->
            <Border Grid.Row="0" Background="{StaticResource PanelBg}"
                    BorderBrush="{StaticResource Hairline}" BorderThickness="0,0,0,1" Padding="14,8">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto" />   <!-- back -->
                        <ColumnDefinition Width="Auto" />   <!-- undo/redo -->
                        <ColumnDefinition Width="Auto" />   <!-- confidence -->
                        <ColumnDefinition Width="160" />
                        <ColumnDefinition Width="36" />
                        <ColumnDefinition Width="Auto" />   <!-- write mode -->
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />   <!-- linked count -->
                        <ColumnDefinition Width="Auto" />   <!-- execute -->
                    </Grid.ColumnDefinitions>

                    <Button Grid.Column="0" Content="← Setup" Style="{StaticResource GhostButton}"
                            Command="{Binding BackToSetupCommand}" Margin="0,0,12,0" />

                    <StackPanel Grid.Column="1" Orientation="Horizontal" Margin="0,0,16,0">
                        <Button Content="↶ Undo" Style="{StaticResource GhostButton}" Margin="0,0,6,0"
                                Command="{Binding UndoCommand}" ToolTip="Ctrl+Z" />
                        <Button Content="↷ Redo" Style="{StaticResource GhostButton}"
                                Command="{Binding RedoCommand}" ToolTip="Ctrl+Y" />
                    </StackPanel>

                    <CheckBox Grid.Column="2" Grid.ColumnSpan="3" Content="Fuzzy match · 90%"
                              IsChecked="{Binding FuzzyEnabled}" VerticalAlignment="Center"
                              ToolTip="Fuzzy matches apply at 90% confidence minimum. Uncheck to only allow exact/synonym matches." />

                    <Border Grid.Column="5" Margin="18,0,0,0" Background="#F2F5FA" CornerRadius="6"
                            BorderBrush="{StaticResource Hairline}" BorderThickness="1" Padding="4">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="Mode:" Foreground="{StaticResource MutedText}" FontSize="11"
                                       VerticalAlignment="Center" Margin="6,0,4,0" />
                            <RadioButton Content="Overwrite" GroupName="WriteMode" Padding="10,3" Margin="2,0"
                                         IsChecked="{Binding AppendMode, Mode=OneWay, Converter={StaticResource BoolToVis}, ConverterParameter=invert}"
                                         Checked="OverwriteRadio_Checked" VerticalContentAlignment="Center"
                                         ToolTip="Replace data rows starting below the target header (asks to confirm)" />
                            <RadioButton Content="Append" GroupName="WriteMode" Padding="10,3" Margin="2,0"
                                         IsChecked="{Binding AppendMode, Mode=OneWay}"
                                         Checked="AppendRadio_Checked" VerticalContentAlignment="Center"
                                         ToolTip="Add rows after the last used row, leaving existing data in place" />
                        </StackPanel>
                    </Border>

                    <!-- Active Parameters Summary Badge -->
                    <StackPanel Grid.Column="6" Orientation="Horizontal" VerticalAlignment="Center" HorizontalAlignment="Center">
                        <Border Background="#F2F5FA" CornerRadius="6" BorderBrush="{StaticResource Hairline}" BorderThickness="1" Padding="8,4">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="Group: " Foreground="{StaticResource MutedText}" FontSize="11" />
                                <TextBlock Text="{Binding GroupIdText}" Foreground="{StaticResource InkText}" FontWeight="SemiBold" FontSize="11" Margin="0,0,10,0" />
                                <TextBlock Text="Insurer: " Foreground="{StaticResource MutedText}" FontSize="11" />
                                <TextBlock Text="{Binding InsurerIdText}" Foreground="{StaticResource InkText}" FontWeight="SemiBold" FontSize="11" Margin="0,0,10,0" />
                                <TextBlock Text="Review: " Foreground="{StaticResource MutedText}" FontSize="11" />
                                <TextBlock Text="{Binding ReviewStart, StringFormat=yyyy-MM-dd}" Foreground="{StaticResource InkText}" FontWeight="SemiBold" FontSize="11" />
                                <TextBlock Text=" to " Foreground="{StaticResource MutedText}" FontSize="11" />
                                <TextBlock Text="{Binding ReviewEnd, StringFormat=yyyy-MM-dd}" Foreground="{StaticResource InkText}" FontWeight="SemiBold" FontSize="11" />
                            </StackPanel>
                        </Border>
                    </StackPanel>

                    <!-- Column mapping counters -->
                    <StackPanel Grid.Column="7" Orientation="Horizontal" VerticalAlignment="Center" Margin="0,0,14,0">
                        <Border Background="#F2F5FA" CornerRadius="6" BorderBrush="{StaticResource Hairline}" BorderThickness="1" Padding="8,4" Margin="0,0,8,0">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="Source: " Foreground="{StaticResource MutedText}" FontSize="11" />
                                <TextBlock Text="{Binding SourceMappedCount}" Foreground="#16A34A" FontWeight="Bold" FontSize="11" />
                                <TextBlock Text=" mapped, " Foreground="{StaticResource MutedText}" FontSize="11" />
                                <!-- unused source columns are normal (more sources than targets) — keep neutral -->
                                <TextBlock Text="{Binding SourceUnmappedCount}" Foreground="{StaticResource MutedText}" FontWeight="Bold" FontSize="11" />
                                <TextBlock Text=" unmapped" Foreground="{StaticResource MutedText}" FontSize="11" />
                            </StackPanel>
                        </Border>
                        <Border Background="#F2F5FA" CornerRadius="6" BorderBrush="{StaticResource Hairline}" BorderThickness="1" Padding="8,4" Margin="0,0,8,0">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="Target: " Foreground="{StaticResource MutedText}" FontSize="11" />
                                <TextBlock Text="{Binding TargetMappedCount}" Foreground="#16A34A" FontWeight="Bold" FontSize="11" />
                                <TextBlock Text=" mapped, " Foreground="{StaticResource MutedText}" FontSize="11" />
                                <!-- unmapped targets are actionable, not errors — amber, not red -->
                                <TextBlock Text="{Binding TargetUnmappedCount}" Foreground="#B45309" FontWeight="Bold" FontSize="11" />
                                <TextBlock Text=" unmapped" Foreground="{StaticResource MutedText}" FontSize="11" />
                            </StackPanel>
                        </Border>
                        <CheckBox Content="Hide Empty Sources" IsChecked="{Binding HideEmptySources}" VerticalAlignment="Center" FontSize="11" Margin="4,0,0,0"
                                  ToolTip="Automatically hides source columns that have no data below the header" />
                    </StackPanel>

                    <Button Grid.Column="8" Content="Execute ▸" Style="{StaticResource PrimaryButton}"
                            MinWidth="140" Command="{Binding WriteCommand}"
                            ToolTip="Write every mapped, non-hidden column to the output copy" />
                </Grid>
            </Border>

            <!-- SOURCE grid (top, ~1/3): header + 10 sample rows, columns across -->
            <Border Grid.Row="1" Background="{StaticResource PanelBg}" BorderBrush="{StaticResource Hairline}"
                    BorderThickness="0,0,0,1">
                <DockPanel>
                    <TextBlock DockPanel.Dock="Top" Text="SOURCE  —  what you're copying from"
                               Style="{StaticResource SectionHeader}" Margin="14,8,14,4" />
                    <ScrollViewer HorizontalScrollBarVisibility="Auto" VerticalScrollBarVisibility="Disabled">
                        <ItemsControl ItemsSource="{Binding VisibleSourceColumns}">
                            <ItemsControl.ItemsPanel>
                                <ItemsPanelTemplate><StackPanel Orientation="Horizontal" /></ItemsPanelTemplate>
                            </ItemsControl.ItemsPanel>
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Border Width="{StaticResource GridColWidth}"
                                            BorderBrush="{StaticResource GridLine}" BorderThickness="0,0,1,0">
                                      <StackPanel>
                                        <!-- header cell; tints green + shows a ✓ once this source is mapped somewhere -->
                                        <Border x:Name="srcHdr" Style="{StaticResource GridHeaderCell}"
                                                BorderThickness="0,0,0,1">
                                            <Grid>
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="*" />
                                                    <ColumnDefinition Width="Auto" />
                                                </Grid.ColumnDefinitions>
                                                <TextBlock Grid.Column="0" Text="{Binding Label}" FontWeight="SemiBold" FontSize="11"
                                                           Foreground="{StaticResource InkText}" TextWrapping="Wrap"
                                                           TextTrimming="CharacterEllipsis" VerticalAlignment="Center"
                                                           ToolTip="{Binding Label}" />
                                                <TextBlock x:Name="srcCheck" Grid.Column="1" Text="✓" FontSize="11" FontWeight="Bold"
                                                           Margin="4,0,0,0" VerticalAlignment="Center" Visibility="Collapsed"
                                                           Foreground="#15803D" ToolTip="Mapped to a target column" />
                                            </Grid>
                                        </Border>
                                        <!-- sample rows -->
                                        <ItemsControl ItemsSource="{Binding SampleCells}" AlternationCount="2">
                                            <ItemsControl.ItemTemplate>
                                                <DataTemplate>
                                                    <Border Style="{StaticResource ZebraRowCell}">
                                                        <TextBlock Text="{Binding}" Style="{StaticResource GridDataCell}"
                                                                   ToolTip="{Binding}" />
                                                    </Border>
                                                </DataTemplate>
                                            </ItemsControl.ItemTemplate>
                                        </ItemsControl>
                                      </StackPanel>
                                    </Border>
                                    <DataTemplate.Triggers>
                                        <DataTrigger Binding="{Binding IsLinked}" Value="True">
                                            <Setter TargetName="srcHdr" Property="Background" Value="{StaticResource AutoTint}" />
                                            <Setter TargetName="srcCheck" Property="Visibility" Value="Visible" />
                                        </DataTrigger>
                                    </DataTemplate.Triggers>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </ScrollViewer>
                </DockPanel>
            </Border>

            <GridSplitter Grid.Row="2" Height="6" HorizontalAlignment="Stretch"
                          Background="{StaticResource WindowBg}" />

            <!-- TARGET grid (bottom, ~2/3): each column header + mapped source preview / picker.
                 Tinted a whisper of blue so SOURCE and TARGET halves read differently at a glance. -->
            <Border Grid.Row="3" Background="{StaticResource TargetPanelBg}">
                <DockPanel>
                    <TextBlock DockPanel.Dock="Top"
                               Text="TARGET  —  click a column body to choose its source · click a header to clear · double-click a header to hide"
                               Style="{StaticResource SectionHeader}" Margin="14,8,14,4" />
                    <ScrollViewer HorizontalScrollBarVisibility="Auto" VerticalScrollBarVisibility="Auto">
                        <ItemsControl ItemsSource="{Binding Rows}">
                            <ItemsControl.ItemsPanel>
                                <ItemsPanelTemplate><StackPanel Orientation="Horizontal" /></ItemsPanelTemplate>
                            </ItemsControl.ItemsPanel>
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Grid>
                                        <!-- ============ HIDDEN: thin restore strip ============ -->
                                        <Border x:Name="hiddenStrip" Width="26" Background="#F0F2F6"
                                                BorderBrush="{StaticResource GridLine}" BorderThickness="0,0,1,0"
                                                Cursor="Hand" ToolTip="Hidden — click to show"
                                                MouseLeftButtonUp="HiddenStrip_Click"
                                                Visibility="{Binding IsHidden, Converter={StaticResource BoolToVis}}">
                                            <TextBlock Text="{Binding HiddenLabel}" FontSize="11"
                                                       Foreground="{StaticResource MutedText}"
                                                       VerticalAlignment="Center" HorizontalAlignment="Center"
                                                       ToolTip="{Binding TargetLabel}">
                                                <TextBlock.LayoutTransform>
                                                    <RotateTransform Angle="90" />
                                                </TextBlock.LayoutTransform>
                                            </TextBlock>
                                        </Border>

                                        <!-- ============ VISIBLE column ============
                                             One right gridline on the column container; inner cells carry only
                                             horizontal separators so there are no doubled/ghost vertical lines. -->
                                        <Border x:Name="col"
                                                BorderBrush="{StaticResource GridLine}" BorderThickness="0,0,1,0"
                                                Visibility="{Binding IsHidden, Converter={StaticResource BoolToVis}, ConverterParameter=invert}">
                                          <Border.Style>
                                              <Style TargetType="Border">
                                                  <Style.Triggers>
                                                      <DataTrigger Binding="{Binding IsFilled}" Value="True">
                                                          <Setter Property="Width" Value="{StaticResource GridColWidth}" />
                                                      </DataTrigger>
                                                      <DataTrigger Binding="{Binding IsFilled}" Value="False">
                                                          <Setter Property="Width" Value="Auto" />
                                                      </DataTrigger>
                                                  </Style.Triggers>
                                              </Style>
                                          </Border.Style>
                                          <StackPanel>
                                            <!-- mapped-source label strip (only when linked) - placed directly ABOVE the header -->
                                            <Border BorderBrush="{StaticResource GridLine}" BorderThickness="0,0,0,1"
                                                    Background="#FBFCFE" Padding="8,3"
                                                    Visibility="{Binding IsLinked, Converter={StaticResource BoolToVis}}">
                                                <StackPanel Orientation="Horizontal">
                                                    <TextBlock Text="← " FontSize="11" Foreground="{StaticResource MutedText}" />
                                                    <TextBlock Text="{Binding LinkedSourceLabel}" FontSize="11"
                                                               FontWeight="SemiBold" Foreground="{StaticResource Accent}"
                                                               TextTrimming="CharacterEllipsis" ToolTip="{Binding LinkedSourceLabel}" />
                                                </StackPanel>
                                            </Border>

                                            <!-- header: single-click = open picker · double-click = clear to blank ·
                                                 right-click = menu (Hide). -->
                                            <Border x:Name="hdr"
                                                    BorderThickness="0,0,0,1"
                                                    MouseLeftButtonDown="TargetHeader_MouseDown">
                                                <Border.Style>
                                                    <Style TargetType="Border" BasedOn="{StaticResource GridHeaderCell}">
                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding IsLocked}" Value="True">
                                                                <Setter Property="Cursor" Value="Arrow" />
                                                                <Setter Property="ToolTip" Value="Parameterized value — cannot be changed or hidden" />
                                                            </DataTrigger>
                                                            <DataTrigger Binding="{Binding IsLocked}" Value="False">
                                                                <Setter Property="Cursor" Value="Hand" />
                                                                <Setter Property="ToolTip" Value="Click to choose · double-click to clear · right-click to hide" />
                                                            </DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </Border.Style>
                                                <Border.ContextMenu>
                                                    <ContextMenu DataContext="{Binding PlacementTarget.DataContext,
                                                                 RelativeSource={RelativeSource Self}}">
                                                        <ContextMenu.Style>
                                                            <Style TargetType="ContextMenu">
                                                                <Style.Triggers>
                                                                    <DataTrigger Binding="{Binding IsLocked}" Value="True">
                                                                        <Setter Property="Visibility" Value="Collapsed" />
                                                                    </DataTrigger>
                                                                </Style.Triggers>
                                                            </Style>
                                                        </ContextMenu.Style>
                                                        <MenuItem Header="Hide column" Click="HideMenuItem_Click" />
                                                    </ContextMenu>
                                                </Border.ContextMenu>
                                                <TextBlock Text="{Binding TargetLabel}" FontWeight="SemiBold"
                                                           FontSize="11" Foreground="{StaticResource InkText}" TextWrapping="Wrap"
                                                           TextTrimming="CharacterEllipsis" VerticalAlignment="Center"
                                                           ToolTip="{Binding TargetLabel}" Margin="4,0" />
                                            </Border>

                                            <!-- BODY: one of three states — Blank (default), Preview (filled), Picker.
                                                 A single right gridline lives on the column itself; cells carry only a
                                                 light horizontal separator, so no doubled/ghost lines. -->
                                            <Grid>
                                                <!-- BLANK: looks empty; a single click opens the picker. -->
                                                <Border x:Name="blank" Background="Transparent" Cursor="Hand"
                                                        MinHeight="120" Padding="8,0"
                                                        MouseLeftButtonUp="TargetBody_Click"
                                                        ToolTip="Click to choose a source or type a value"
                                                        Visibility="{Binding BodyState, Converter={StaticResource StateToVis}, ConverterParameter=Blank}" />

                                                <!-- PREVIEW: the filled column's repeated/source values.
                                                     Single-click re-opens the picker; double-click clears to blank. -->
                                                <Border x:Name="preview" Cursor="Hand" Background="Transparent"
                                                        MouseLeftButtonDown="TargetBody_MouseDown"
                                                        Visibility="{Binding BodyState, Converter={StaticResource StateToVis}, ConverterParameter=Preview}">
                                                    <ItemsControl ItemsSource="{Binding SampleCells}" AlternationCount="2">
                                                        <ItemsControl.ItemTemplate>
                                                            <DataTemplate>
                                                                <Border Style="{StaticResource ZebraRowCell}">
                                                                    <TextBlock Text="{Binding}" Style="{StaticResource GridDataCell}"
                                                                               ToolTip="{Binding}" />
                                                                </Border>
                                                            </DataTemplate>
                                                        </ItemsControl.ItemTemplate>
                                                    </ItemsControl>
                                                </Border>

                                                <!-- PICKER: a type-a-value box, a type-ahead filter, then the source list
                                                     capped to a scrollable height — open pickers stay compact instead of
                                                     unrolling every source column down the grid. -->
                                                <Border x:Name="picker" Background="White"
                                                        Visibility="{Binding BodyState, Converter={StaticResource StateToVis}, ConverterParameter=Picker}">
                                                    <StackPanel>
                                                        <!-- type a constant: fills EVERY row of this column -->
                                                        <Border Background="#FFFBEC" BorderBrush="{StaticResource GridLine}"
                                                                BorderThickness="0,0,0,1" Padding="4,3">
                                                            <TextBox FontSize="12" Tag="{Binding}"
                                                                     KeyDown="ConstantBox_KeyDown"
                                                                     LostFocus="ConstantBox_LostFocus"
                                                                     ToolTip="Type a value, then press Enter or click away — it fills every row of this column">
                                                                <TextBox.Style>
                                                                    <Style TargetType="TextBox" BasedOn="{StaticResource {x:Type TextBox}}">
                                                                        <Setter Property="Padding" Value="3,2" />
                                                                    </Style>
                                                                </TextBox.Style>
                                                            </TextBox>
                                                        </Border>
                                                        <TextBlock Text="— or pick a source —" FontSize="10"
                                                                   Foreground="{StaticResource MutedText}"
                                                                   HorizontalAlignment="Center" Margin="0,3" />
                                                        <TextBox FontSize="11" Margin="3,0,3,3" Padding="3,2"
                                                                 TextChanged="PickerFilter_TextChanged"
                                                                 ToolTip="Type to filter the source list" />
                                                        <ScrollViewer MaxHeight="220" VerticalScrollBarVisibility="Auto"
                                                                      HorizontalScrollBarVisibility="Disabled">
                                                            <ItemsControl ItemsSource="{Binding DataContext.PickableSourceColumns, RelativeSource={RelativeSource AncestorType=Window}}">
                                                                <ItemsControl.ItemTemplate>
                                                                    <DataTemplate>
                                                                        <Border Cursor="Hand"
                                                                                Tag="{Binding}" MouseLeftButtonUp="PickerOption_Click">
                                                                            <Border.Style>
                                                                                <Style TargetType="Border" BasedOn="{StaticResource PickerOption}">
                                                                                    <Style.Triggers>
                                                                                        <Trigger Property="IsMouseOver" Value="True">
                                                                                            <Setter Property="Background" Value="#F0F6FF" />
                                                                                        </Trigger>
                                                                                    </Style.Triggers>
                                                                                </Style>
                                                                            </Border.Style>
                                                                            <TextBlock Text="{Binding Label}" FontSize="12"
                                                                                       Foreground="{StaticResource InkText}"
                                                                                       TextTrimming="CharacterEllipsis" ToolTip="{Binding Label}" />
                                                                        </Border>
                                                                    </DataTemplate>
                                                                </ItemsControl.ItemTemplate>
                                                            </ItemsControl>
                                                        </ScrollViewer>
                                                    </StackPanel>
                                                </Border>
                                            </Grid>
                                          </StackPanel>
                                        </Border>
                                    </Grid>

                                    <DataTemplate.Triggers>
                                        <!-- tint filled slots: auto = green, fuzzy auto = amber (review me),
                                             manual/constant = blue -->
                                        <DataTrigger Binding="{Binding IsLinked}" Value="True">
                                            <Setter TargetName="hdr" Property="Background" Value="{StaticResource AutoTint}" />
                                        </DataTrigger>
                                        <DataTrigger Binding="{Binding IsFuzzyAuto}" Value="True">
                                            <Setter TargetName="hdr" Property="Background" Value="{StaticResource WarnBg}" />
                                        </DataTrigger>
                                        <DataTrigger Binding="{Binding IsManualOverride}" Value="True">
                                            <Setter TargetName="hdr" Property="Background" Value="{StaticResource ManualTint}" />
                                        </DataTrigger>
                                        <DataTrigger Binding="{Binding IsConstant}" Value="True">
                                            <Setter TargetName="hdr" Property="Background" Value="{StaticResource ManualTint}" />
                                        </DataTrigger>
                                    </DataTemplate.Triggers>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </ScrollViewer>
                </DockPanel>
            </Border>

            <!-- status footer: match-quality tally up front, then the narrative status -->
            <Border Grid.Row="4" Background="{StaticResource PanelBg}" BorderBrush="{StaticResource Hairline}"
                    BorderThickness="0,1,0,0" Padding="14,8">
                <DockPanel>
                    <StackPanel DockPanel.Dock="Left" Orientation="Horizontal" VerticalAlignment="Center"
                                Margin="0,0,12,0"
                                Visibility="{Binding HasMatched, Converter={StaticResource BoolToVis}}">
                        <Border Background="{StaticResource AutoTint}" CornerRadius="4" Padding="7,2" Margin="0,0,5,0">
                            <TextBlock FontSize="11" FontWeight="SemiBold" Foreground="#15803D"
                                       Text="{Binding ExactCount, StringFormat={}exact {0}}"
                                       ToolTip="Header names matched exactly" />
                        </Border>
                        <Border Background="#E8F1FF" CornerRadius="4" Padding="7,2" Margin="0,0,5,0">
                            <TextBlock FontSize="11" FontWeight="SemiBold" Foreground="#0E6BA8"
                                       Text="{Binding AliasCount, StringFormat={}alias {0}}"
                                       ToolTip="Matched through a synonym group" />
                        </Border>
                        <Border Background="#F1EAFB" CornerRadius="4" Padding="7,2" Margin="0,0,5,0">
                            <TextBlock FontSize="11" FontWeight="SemiBold" Foreground="#6D28D9"
                                       Text="{Binding QualifiedCount, StringFormat={}qualified {0}}"
                                       ToolTip="Matched through a qualified rule" />
                        </Border>
                        <Border Background="{StaticResource WarnBg}" CornerRadius="4" Padding="7,2">
                            <TextBlock FontSize="11" FontWeight="SemiBold" Foreground="{StaticResource WarnText}"
                                       Text="{Binding FuzzyCount, StringFormat={}fuzzy {0}}"
                                       ToolTip="Fuzzy matches (90%+) — worth a glance; their headers are tinted amber" />
                        </Border>
                    </StackPanel>
                    <StackPanel DockPanel.Dock="Right" Orientation="Horizontal" VerticalAlignment="Center"
                                Margin="12,0,0,0">
                        <TextBlock Text="Aa" FontSize="11" Foreground="{StaticResource MutedText}"
                                   VerticalAlignment="Center" Margin="0,0,5,0" />
                        <ComboBox Width="110" FontSize="11" ItemsSource="{Binding DensityOptions}"
                                  SelectedItem="{Binding UiDensity}"
                                  ToolTip="Display size — Large for easier reading, Compact for more on screen" />
                    </StackPanel>
                    <TextBlock Text="{Binding Status}" TextWrapping="Wrap" VerticalAlignment="Center"
                               Foreground="{StaticResource InkText}" FontSize="12" />
                </DockPanel>
            </Border>
        </Grid>
    </Grid>
</Window>
