<Window x:Class="CelMap.App.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:CelMap.App"
        mc:Ignorable="d"
        Title="CelMap — Excel Column Mapper"
        Height="960" Width="1000" MinHeight="720" MinWidth="900"
        WindowStartupLocation="CenterScreen"
        Background="{StaticResource WindowBg}"
        d:DataContext="{d:DesignInstance local:MainViewModel}">

    <!-- Undo/redo apply on the mapping screen; commands self-disable elsewhere. -->
    <Window.InputBindings>
        <KeyBinding Key="Z" Modifiers="Control" Command="{Binding Mapping.UndoCommand}" />
        <KeyBinding Key="Y" Modifiers="Control" Command="{Binding Mapping.RedoCommand}" />
    </Window.InputBindings>

    <Grid>
        <!-- Display density: the entire UI scales from one transform, so every element
             (fonts, paddings, grids) stays proportionate across the three tiers. -->
        <Grid.LayoutTransform>
            <ScaleTransform ScaleX="{Binding UiScale}" ScaleY="{Binding UiScale}" />
        </Grid.LayoutTransform>

        <!-- Screen 0 — Parameters Setup -->
        <local:ParametersView Visibility="{Binding IsOnParameters, Converter={StaticResource BoolToVis}}" />

        <!-- Screen 1 — Setup (compact) -->
        <local:SetupView Visibility="{Binding IsOnSetup, Converter={StaticResource BoolToVis}}" />

        <!-- Screen 2 — Mapping (full window, Excel-like) -->
        <local:MappingView Visibility="{Binding IsOnMapping, Converter={StaticResource BoolToVis}}" />
    </Grid>
</Window>
