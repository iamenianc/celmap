<UserControl x:Class="CelMap.App.MappingView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:CelMap.App"
             mc:Ignorable="d" 
             d:DataContext="{d:DesignInstance local:MappingViewModel}">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />   <!-- top bar -->
            <RowDefinition Height="2*" />     <!-- source grid -->
            <RowDefinition Height="Auto" />   <!-- splitter -->
            <RowDefinition Height="3*" />     <!-- target grid -->
            <RowDefinition Height="Auto" />   <!-- status -->
        </Grid.RowDefinitions>

        <!-- Slim top bar -->
        <Border Grid.Row="0" Background="{StaticResource PanelBg}"
                BorderBrush="{StaticResource Hairline}" BorderThickness="0,0,0,1" Padding="14,8">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />   <!-- back + undo/redo + fuzzy -->
                    <ColumnDefinition Width="*" />      <!-- badges + counters + toggles (wraps) -->
                    <ColumnDefinition Width="Auto" />   <!-- execute -->
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center" Margin="0,0,16,0">
                    <Button Content="← Setup" Style="{StaticResource GhostButton}"
                            Command="{Binding DataContext.BackToSetupCommand, RelativeSource={RelativeSource AncestorType=Window}}" Margin="0,0,12,0" />
                    <Button Content="↶ Undo" Style="{StaticResource GhostButton}" Margin="0,0,6,0"
                            Command="{Binding UndoCommand}" ToolTip="Ctrl+Z" />
                    <Button Content="↷ Redo" Style="{StaticResource GhostButton}" Margin="0,0,16,0"
                            Command="{Binding RedoCommand}" ToolTip="Ctrl+Y" />
                    <CheckBox Content="Fuzzy match · 90%"
                              IsChecked="{Binding DataContext.FuzzyEnabled, RelativeSource={RelativeSource AncestorType=Window}}" VerticalAlignment="Center" Margin="0,0,16,0"
                              ToolTip="Fuzzy matches apply at 90% confidence minimum. Uncheck to only allow exact/synonym matches." />
                    <CheckBox Content="Hide Empty Sources"
                              IsChecked="{Binding HideEmptySources}" VerticalAlignment="Center" Margin="0,0,16,0"
                              ToolTip="Automatically hides source columns that have no data below the header" />
                    <CheckBox Content="Hide Mapped Sources"
                              IsChecked="{Binding HideMappedSources}" VerticalAlignment="Center"
                              ToolTip="Hides source columns that have already been mapped to a target" />
                </StackPanel>

                <WrapPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center"
                           HorizontalAlignment="Right" Margin="8,0,14,0">
                    <!-- Active Parameters Summary Badge -->
                    <Border Background="#f8faf9" CornerRadius="6" BorderBrush="{StaticResource Hairline}" BorderThickness="1" Padding="8,4" Margin="0,2,8,2">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="Group: " Foreground="{StaticResource MutedText}" FontSize="11" />
                            <TextBlock Text="{Binding DataContext.Parameters.GroupIdText, RelativeSource={RelativeSource AncestorType=Window}}" Foreground="{StaticResource InkText}" FontWeight="SemiBold" FontSize="11" Margin="0,0,10,0" />
                            <TextBlock Text="Review Start: " Foreground="{StaticResource MutedText}" FontSize="11" />
                            <TextBlock Text="{Binding DataContext.Parameters.ReviewStart, StringFormat=yyyy-MM-dd, RelativeSource={RelativeSource AncestorType=Window}}" Foreground="{StaticResource InkText}" FontWeight="SemiBold" FontSize="11" />
                        </StackPanel>
                    </Border>

                </WrapPanel>

                <!-- Scale density dropdown -->
                <StackPanel Grid.Column="2" Orientation="Horizontal" VerticalAlignment="Center" Margin="12,0,0,0">
                    <TextBlock Text="Aa" FontSize="11" Foreground="{StaticResource MutedText}"
                               VerticalAlignment="Center" Margin="0,0,5,0" />
                    <ComboBox Width="110" FontSize="11"
                              ItemsSource="{Binding DataContext.DensityOptions, RelativeSource={RelativeSource AncestorType=Window}}"
                              SelectedItem="{Binding DataContext.UiDensity, RelativeSource={RelativeSource AncestorType=Window}}"
                              ToolTip="Display size — Large for easier reading, Compact for more on screen" />
                </StackPanel>
            </Grid>
        </Border>

        <!-- SOURCE grid (top) -->
        <Border Grid.Row="1" Background="{StaticResource PanelBg}" BorderBrush="{StaticResource Hairline}"
                BorderThickness="0,0,0,1">
            <DockPanel>
                <DockPanel DockPanel.Dock="Top" Margin="14,8,14,4">
                    <StackPanel DockPanel.Dock="Right" Orientation="Horizontal" VerticalAlignment="Center">
                        <TextBlock Text="Sheet:" FontSize="11" Foreground="{StaticResource MutedText}"
                                   VerticalAlignment="Center" Margin="0,0,6,0" />
                        <ComboBox Width="160" FontSize="11"
                                  ItemsSource="{Binding SourceSheets}"
                                  SelectedItem="{Binding SelectedSourceSheet}"
                                  ToolTip="Switch the source to a different worksheet — re-runs the match against the same target" />
                    </StackPanel>
                    <TextBlock Style="{StaticResource SectionHeader}" VerticalAlignment="Center">
                        <Run Text="SOURCE  —  " /><Run Text="{Binding DataContext.Setup.SourceFilePath, Mode=OneWay, RelativeSource={RelativeSource AncestorType=Window}}" Foreground="{StaticResource InkText}" />
                    </TextBlock>
                </DockPanel>
                
                <!-- Source footer / badge -->
                <Border DockPanel.Dock="Bottom" Background="{StaticResource PanelBg}"
                        BorderBrush="{StaticResource Hairline}" BorderThickness="0,1,0,0" Padding="14,6">
                    <StackPanel Orientation="Horizontal">
                        <Border Background="#f8faf9" CornerRadius="6" BorderBrush="{StaticResource Hairline}" BorderThickness="1" Padding="8,4">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="Source: " Foreground="{StaticResource MutedText}" FontSize="11" />
                                <TextBlock Text="{Binding SourceMappedCount}" Foreground="#2d7d50" FontWeight="Bold" FontSize="11" />
                                <TextBlock Text=" mapped, " Foreground="{StaticResource MutedText}" FontSize="11" />
                                <TextBlock Text="{Binding SourceUnmappedCount}" Foreground="{StaticResource MutedText}" FontWeight="Bold" FontSize="11" />
                                <TextBlock Text=" unmapped" Foreground="{StaticResource MutedText}" FontSize="11" />
                            </StackPanel>
                        </Border>
                    </StackPanel>
                </Border>

                <ScrollViewer HorizontalScrollBarVisibility="Auto" VerticalScrollBarVisibility="Auto">
                    <ItemsControl ItemsSource="{Binding VisibleSourceColumns}">
                        <ItemsControl.ItemsPanel>
                            <ItemsPanelTemplate><StackPanel Orientation="Horizontal" /></ItemsPanelTemplate>
                        </ItemsControl.ItemsPanel>
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <!-- Width is Auto so each source column is only as wide as its header
                                     needs. MinWidth ~= 11 chars so empty/1-char headers stay readable;
                                     MaxWidth caps the column so a long header can't dominate the table —
                                     past it the header wraps. -->
                                <Border Background="Transparent" MinWidth="80" MaxWidth="140"
                                        BorderBrush="{StaticResource GridLine}" BorderThickness="0,0,1,0"
                                        MouseLeftButtonDown="SourceColumn_MouseDown"
                                        MouseEnter="SourceColumn_MouseEnter"
                                        MouseLeave="SourceColumn_MouseLeave">
                                   <StackPanel>
                                        <!-- HEADER CONTAINER (frozen) -->
                                        <StackPanel Panel.ZIndex="1">
                                            <StackPanel.RenderTransform>
                                                <TranslateTransform Y="{Binding VerticalOffset, RelativeSource={RelativeSource AncestorType=ScrollViewer}}" />
                                            </StackPanel.RenderTransform>
                                            
                                            <!-- mapped-target label strip -->
                                            <Border BorderBrush="{StaticResource GridLine}" BorderThickness="0,0,0,1"
                                                    Background="#ffffff" Padding="8,3" Height="24"
                                                    Width="{Binding ActualWidth, ElementName=srcHdr}">
                                                <Grid Visibility="{Binding IsLinked, Converter={StaticResource BoolToVis}, ConverterParameter=hidden}">
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="Auto" />
                                                        <ColumnDefinition Width="*" />
                                                    </Grid.ColumnDefinitions>
                                                    <TextBlock Grid.Column="0" Text="→ " FontSize="11" Foreground="{StaticResource MutedText}" />
                                                    <TextBlock Grid.Column="1" Text="{Binding MappedTargetLabel}" FontSize="11"
                                                               FontWeight="SemiBold" Foreground="{StaticResource Accent}"
                                                               TextTrimming="CharacterEllipsis" ToolTip="{Binding MappedTargetLabel}" />
                                                </Grid>
                                            </Border>
                                            
                                            <Border x:Name="srcHdr"
                                                    BorderThickness="0,0,0,1">
                                                <Border.Style>
                                                    <Style TargetType="Border" BasedOn="{StaticResource GridHeaderCell}">
                                                        <Setter Property="Cursor" Value="Hand" />
                                                        <Setter Property="ToolTip" Value="Click to pick this source, then click a target below" />
                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding IsLinked}" Value="True">
                                                                <Setter Property="ToolTip" Value="Click to pick · double-click to clear mappings · right-click to unmap" />
                                                            </DataTrigger>
                                                            <!-- Pre-click aim feedback: tint the header the cursor is over. -->
                                                            <Trigger Property="IsMouseOver" Value="True">
                                                                <Setter Property="Background" Value="{StaticResource DropZoneBg}" />
                                                            </Trigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </Border.Style>
                                                <Border.ContextMenu>
                                                    <ContextMenu DataContext="{Binding PlacementTarget.DataContext,
                                                                 RelativeSource={RelativeSource Self}}">
                                                        <MenuItem Header="Clear mappings" Click="SourceClearMenuItem_Click"
                                                                  IsEnabled="{Binding IsLinked}" />
                                                    </ContextMenu>
                                                </Border.ContextMenu>
                                                <Grid>
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="*" />
                                                        <ColumnDefinition Width="Auto" />
                                                    </Grid.ColumnDefinitions>
                                                    <TextBlock Grid.Column="0" Text="{Binding Label}" FontWeight="SemiBold" FontSize="11"
                                                               Foreground="{StaticResource InkText}" TextWrapping="Wrap"
                                                               TextTrimming="CharacterEllipsis" VerticalAlignment="Center" MaxWidth="126"
                                                               ToolTip="{Binding Label}" />
                                                    <TextBlock x:Name="srcCheck" Grid.Column="1" Text="✓" FontSize="11" FontWeight="Bold"
                                                               Margin="4,0,0,0" VerticalAlignment="Center" Visibility="Collapsed"
                                                               Foreground="#2d7d50" ToolTip="Mapped to a target column" />
                                                </Grid>
                                            </Border>
                                        </StackPanel>

                                        <!-- Data cells must not widen the column past the header: cap each
                                             cell to the header's width and trim with an ellipsis. -->
                                        <ItemsControl ItemsSource="{Binding SampleCells}" AlternationCount="2" Panel.ZIndex="0"
                                                      Width="{Binding ActualWidth, ElementName=srcHdr}">
                                            <ItemsControl.ItemTemplate>
                                                <DataTemplate>
                                                    <Border Style="{StaticResource ZebraRowCell}">
                                                        <TextBlock Text="{Binding}" Style="{StaticResource GridDataCell}"
                                                                   TextTrimming="CharacterEllipsis" ToolTip="{Binding}" />
                                                    </Border>
                                                </DataTemplate>
                                            </ItemsControl.ItemTemplate>
                                        </ItemsControl>
                                   </StackPanel>
                                </Border>
                                <DataTemplate.Triggers>
                                    <DataTrigger Binding="{Binding IsLinked}" Value="True">
                                        <Setter TargetName="srcHdr" Property="Background" Value="{StaticResource AutoTint}" />
                                        <Setter TargetName="srcCheck" Property="Visibility" Value="Visible" />
                                    </DataTrigger>
                                    <!-- Hover-sync: target hovered, this is its mapped source. -->
                                    <DataTrigger Binding="{Binding IsHoverHighlighted}" Value="True">
                                        <Setter TargetName="srcHdr" Property="BorderBrush" Value="{StaticResource Accent}" />
                                        <Setter TargetName="srcHdr" Property="BorderThickness" Value="2" />
                                    </DataTrigger>
                                    <!-- Armed for click-to-link: highlight so the user sees what they picked. -->
                                    <DataTrigger Binding="{Binding IsPicked}" Value="True">
                                        <Setter TargetName="srcHdr" Property="Background" Value="{StaticResource ManualTint}" />
                                        <Setter TargetName="srcHdr" Property="BorderBrush" Value="{StaticResource Accent}" />
                                        <Setter TargetName="srcHdr" Property="BorderThickness" Value="2" />
                                    </DataTrigger>
                                </DataTemplate.Triggers>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </ScrollViewer>
            </DockPanel>
        </Border>

        <GridSplitter Grid.Row="2" Height="6" HorizontalAlignment="Stretch"
                      Background="{StaticResource WindowBg}" />


        <!-- TARGET grid (bottom) -->
        <Border Grid.Row="3" Background="{StaticResource TargetPanelBg}">
            <DockPanel>
                <!-- Hide-row toggle bar -->
                <Border DockPanel.Dock="Top" Background="{StaticResource PanelBg}"
                        BorderBrush="{StaticResource Hairline}" BorderThickness="0,0,0,1" Padding="14,6">
                    <WrapPanel Orientation="Horizontal" VerticalAlignment="Center">
                        <TextBlock Text="View:" FontSize="11" FontWeight="SemiBold"
                                   Foreground="{StaticResource MutedText}" VerticalAlignment="Center" Margin="0,0,12,0" />
                        <CheckBox Content="Hide Unmapped Targets" IsChecked="{Binding HideUnmappedTargets}" VerticalAlignment="Center" FontSize="11" Margin="0,2,16,2"
                                   ToolTip="Show only target columns that are already mapped (turns off &quot;Hide Mapped Targets&quot;)" />
                        <CheckBox Content="Hide Mapped Targets" IsChecked="{Binding HideMappedTargets}" VerticalAlignment="Center" FontSize="11" Margin="0,2,0,2"
                                   ToolTip="Show only target columns that still need a mapping (turns off &quot;Hide Unmapped Targets&quot;)" />
                    </WrapPanel>
                </Border>

                <TextBlock DockPanel.Dock="Top" Style="{StaticResource SectionHeader}" Margin="14,8,14,4">
                    <Run Text="TARGET  " /><Run Text="{Binding DataContext.Setup.TargetFileName, Mode=OneWay, RelativeSource={RelativeSource AncestorType=Window}}" Foreground="{StaticResource InkText}" />
                </TextBlock>
                <ScrollViewer HorizontalScrollBarVisibility="Auto" VerticalScrollBarVisibility="Auto">
                    <ItemsControl ItemsSource="{Binding VisibleRows}">
                        <ItemsControl.ItemsPanel>
                            <ItemsPanelTemplate><StackPanel Orientation="Horizontal" /></ItemsPanelTemplate>
                        </ItemsControl.ItemsPanel>
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Grid>
                                    <!-- ============ HIDDEN: thin restore strip ============ -->
                                    <Border x:Name="hiddenStrip" Width="26" Background="#f0f3f1"
                                            BorderBrush="{StaticResource GridLine}" BorderThickness="0,0,1,0"
                                            Cursor="Hand" ToolTip="Hidden — click to show"
                                            MouseLeftButtonUp="HiddenStrip_Click"
                                            Visibility="{Binding IsHidden, Converter={StaticResource BoolToVis}}">
                                        <TextBlock Text="{Binding HiddenLabel}" FontSize="11"
                                                   Foreground="{StaticResource MutedText}"
                                                   VerticalAlignment="Center" HorizontalAlignment="Center"
                                                   ToolTip="{Binding TargetLabel}">
                                            <TextBlock.LayoutTransform>
                                                <RotateTransform Angle="90" />
                                            </TextBlock.LayoutTransform>
                                        </TextBlock>
                                    </Border>

                                    <!-- ============ VISIBLE column ============ -->
                                    <!-- Same width logic as the source columns: Auto so the column is only
                                         as wide as its header. MinWidth ~= 11 chars so empty/1-char headers
                                         stay readable; MaxWidth caps the column so a long header can't
                                         dominate the table — past it the header wraps. -->
                                    <Border x:Name="col" MinWidth="80" MaxWidth="140"
                                            BorderBrush="{StaticResource GridLine}" BorderThickness="0,0,1,0"
                                            MouseEnter="TargetColumn_MouseEnter"
                                            MouseLeave="TargetColumn_MouseLeave"
                                            Visibility="{Binding IsHidden, Converter={StaticResource BoolToVis}, ConverterParameter=invert}">
                                      <StackPanel>
                                        <!-- HEADER CONTAINER (frozen) -->
                                        <StackPanel Panel.ZIndex="1">
                                            <StackPanel.RenderTransform>
                                                <TranslateTransform Y="{Binding VerticalOffset, RelativeSource={RelativeSource AncestorType=ScrollViewer}}" />
                                            </StackPanel.RenderTransform>
                                            
                                            <!-- mapped-source label strip -->
                                            <Border BorderBrush="{StaticResource GridLine}" BorderThickness="0,0,0,1"
                                                    Background="#ffffff" Padding="8,3" Height="24"
                                                    Width="{Binding ActualWidth, ElementName=hdr}">
                                                <Grid Visibility="{Binding IsLinked, Converter={StaticResource BoolToVis}, ConverterParameter=hidden}">
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="Auto" />
                                                        <ColumnDefinition Width="*" />
                                                    </Grid.ColumnDefinitions>
                                                    <TextBlock Grid.Column="0" Text="← " FontSize="11" Foreground="{StaticResource MutedText}" />
                                                    <TextBlock Grid.Column="1" Text="{Binding LinkedSourceLabel}" FontSize="11"
                                                               FontWeight="SemiBold" Foreground="{StaticResource Accent}"
                                                               TextTrimming="CharacterEllipsis" ToolTip="{Binding LinkedSourceLabel}" />
                                                </Grid>
                                            </Border>

                                            <!-- header -->
                                            <Border x:Name="hdr"
                                                    BorderThickness="0,0,0,1"
                                                    MouseLeftButtonDown="TargetHeader_MouseDown"
                                                    Tag="{Binding DataContext, RelativeSource={RelativeSource AncestorType=UserControl}}">
                                                <Border.Style>
                                                    <Style TargetType="Border" BasedOn="{StaticResource GridHeaderCell}">
                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding IsLocked}" Value="True">
                                                                <Setter Property="Cursor" Value="Arrow" />
                                                                <Setter Property="ToolTip" Value="Parameterized value — cannot be changed or hidden" />
                                                            </DataTrigger>
                                                            <DataTrigger Binding="{Binding IsLocked}" Value="False">
                                                                <Setter Property="Cursor" Value="Hand" />
                                                                <Setter Property="ToolTip" Value="Click to link the picked source · right-click → Map · double-click to clear" />
                                                            </DataTrigger>
                                                            <!-- Pre-click aim feedback: tint the header the cursor is over. -->
                                                            <Trigger Property="IsMouseOver" Value="True">
                                                                <Setter Property="Background" Value="{StaticResource DropZoneBg}" />
                                                            </Trigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </Border.Style>
                                                <Border.ContextMenu>
                                                    <ContextMenu DataContext="{Binding PlacementTarget.DataContext,
                                                                 RelativeSource={RelativeSource Self}}">
                                                        <ContextMenu.Style>
                                                            <Style TargetType="ContextMenu">
                                                                <Style.Triggers>
                                                                    <DataTrigger Binding="{Binding IsLocked}" Value="True">
                                                                        <Setter Property="Visibility" Value="Collapsed" />
                                                                    </DataTrigger>
                                                                </Style.Triggers>
                                                            </Style>
                                                        </ContextMenu.Style>
                                                        <MenuItem Header="Map"
                                                                  IsEnabled="{Binding HasItems, RelativeSource={RelativeSource Self}}">
                                                            <MenuItem.ItemsSource>
                                                                <MultiBinding Converter="{StaticResource AvailableSourcesForRow}">
                                                                    <Binding Path="PlacementTarget.Tag.SourceColumns" RelativeSource="{RelativeSource AncestorType=ContextMenu}" />
                                                                    <Binding Path="PlacementTarget.DataContext" RelativeSource="{RelativeSource AncestorType=ContextMenu}" />
                                                                </MultiBinding>
                                                            </MenuItem.ItemsSource>
                                                            <MenuItem.ItemContainerStyle>
                                                                <Style TargetType="MenuItem">
                                                                    <Setter Property="Header" Value="{Binding Label}" />
                                                                    <EventSetter Event="Click" Handler="MapMenuItem_Click" />
                                                                </Style>
                                                            </MenuItem.ItemContainerStyle>
                                                        </MenuItem>
                                                        <Separator />
                                                        <MenuItem Header="Copy"
                                                                  IsEnabled="{Binding HasItems, RelativeSource={RelativeSource Self}}">
                                                            <MenuItem.ItemsSource>
                                                                <MultiBinding Converter="{StaticResource ExcludeCurrentItem}">
                                                                    <Binding Path="PlacementTarget.Tag.MappedRows" RelativeSource="{RelativeSource AncestorType=ContextMenu}" />
                                                                    <Binding Path="PlacementTarget.DataContext" RelativeSource="{RelativeSource AncestorType=ContextMenu}" />
                                                                </MultiBinding>
                                                            </MenuItem.ItemsSource>
                                                            <MenuItem.ItemContainerStyle>
                                                                <Style TargetType="MenuItem">
                                                                    <Setter Property="Header" Value="{Binding TargetLabel}" />
                                                                    <EventSetter Event="Click" Handler="CopyMenuItem_Click" />
                                                                </Style>
                                                            </MenuItem.ItemContainerStyle>
                                                        </MenuItem>
                                                        <MenuItem Header="Clear column" Click="ClearMenuItem_Click"
                                                                  IsEnabled="{Binding IsFilled}" />
                                                        <MenuItem Header="Hide column" Click="HideMenuItem_Click" />
                                                    </ContextMenu>
                                                </Border.ContextMenu>
                                                <!-- Wrapped in a *-width Grid (like the source header) so the
                                                     TextBlock has a definite width to wrap into rather than
                                                     measuring at its full single-line width. -->
                                                <Grid>
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="*" />
                                                    </Grid.ColumnDefinitions>
                                                    <TextBlock Grid.Column="0" Text="{Binding TargetLabel}" FontWeight="SemiBold"
                                                               FontSize="11" Foreground="{StaticResource InkText}" TextWrapping="Wrap"
                                                               TextTrimming="CharacterEllipsis" VerticalAlignment="Center" MaxWidth="126"
                                                               ToolTip="{Binding TargetLabel}" Margin="4,0" />
                                                </Grid>
                                            </Border>
                                        </StackPanel>

                                        <!-- BODY -->
                                        <Grid Panel.ZIndex="0">
                                            <!-- BLANK -->
                                            <Border x:Name="blank" Background="Transparent"
                                                    MinHeight="120" Padding="8,0"
                                                    ToolTip="Right-click the header → Map to choose a source"
                                                    Visibility="{Binding BodyState, Converter={StaticResource StateToVis}, ConverterParameter=Blank}" />

                                            <!-- PREVIEW — cells lock to the header width and trim with an
                                                 ellipsis, so a long value can't widen the column past its header. -->
                                            <Border x:Name="preview" Background="Transparent"
                                                    Visibility="{Binding BodyState, Converter={StaticResource StateToVis}, ConverterParameter=Preview}">
                                                <ItemsControl ItemsSource="{Binding SampleCells}" AlternationCount="2"
                                                              Width="{Binding ActualWidth, ElementName=hdr}">
                                                    <ItemsControl.ItemTemplate>
                                                        <DataTemplate>
                                                            <Border Style="{StaticResource ZebraRowCell}">
                                                                <TextBlock Text="{Binding}" Style="{StaticResource GridDataCell}"
                                                                           TextTrimming="CharacterEllipsis" ToolTip="{Binding}" />
                                                            </Border>
                                                        </DataTemplate>
                                                    </ItemsControl.ItemTemplate>
                                                </ItemsControl>
                                            </Border>
                                         </Grid>
                                      </StackPanel>
                                    </Border>
                                </Grid>

                                <DataTemplate.Triggers>
                                    <DataTrigger Binding="{Binding IsLinked}" Value="True">
                                        <Setter TargetName="hdr" Property="Background" Value="{StaticResource AutoTint}" />
                                    </DataTrigger>
                                    <DataTrigger Binding="{Binding IsFuzzyAuto}" Value="True">
                                        <Setter TargetName="hdr" Property="Background" Value="{StaticResource WarnBg}" />
                                    </DataTrigger>
                                    <DataTrigger Binding="{Binding IsManualOverride}" Value="True">
                                        <Setter TargetName="hdr" Property="Background" Value="{StaticResource ManualTint}" />
                                    </DataTrigger>
                                    <DataTrigger Binding="{Binding IsConstant}" Value="True">
                                        <Setter TargetName="hdr" Property="Background" Value="{StaticResource ManualTint}" />
                                    </DataTrigger>
                                    <!-- Hover-sync: source hovered, this is its mapped target. -->
                                    <DataTrigger Binding="{Binding IsHoverHighlighted}" Value="True">
                                        <Setter TargetName="hdr" Property="BorderBrush" Value="{StaticResource Accent}" />
                                        <Setter TargetName="hdr" Property="BorderThickness" Value="2" />
                                    </DataTrigger>
                                </DataTemplate.Triggers>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </ScrollViewer>
            </DockPanel>
        </Border>

        <!-- status footer -->
        <Border Grid.Row="4" BorderBrush="{StaticResource Hairline}"
                BorderThickness="0,1,0,0" Padding="14,8">
            <Border.Style>
                <Style TargetType="Border">
                    <Setter Property="Background">
                        <Setter.Value>
                            <SolidColorBrush Color="#ffffff" />
                        </Setter.Value>
                    </Setter>
                    <Style.Triggers>
                        <DataTrigger Binding="{Binding DataContext.StatusFlash, RelativeSource={RelativeSource AncestorType=Window}}" Value="True">
                            <DataTrigger.EnterActions>
                                <BeginStoryboard x:Name="FlashBgStoryboard">
                                    <Storyboard RepeatBehavior="Forever">
                                        <ColorAnimation Storyboard.TargetProperty="Background.Color"
                                                        To="#2d7d50" Duration="0:0:1.25" AutoReverse="True" />
                                    </Storyboard>
                                </BeginStoryboard>
                            </DataTrigger.EnterActions>
                            <DataTrigger.ExitActions>
                                <RemoveStoryboard BeginStoryboardName="FlashBgStoryboard" />
                                <BeginStoryboard>
                                    <Storyboard>
                                        <ColorAnimation Storyboard.TargetProperty="Background.Color"
                                                        To="#ffffff" Duration="0:0:0.6" />
                                    </Storyboard>
                                </BeginStoryboard>
                            </DataTrigger.ExitActions>
                        </DataTrigger>
                    </Style.Triggers>
                </Style>
            </Border.Style>
            <DockPanel>
                <StackPanel DockPanel.Dock="Left" Orientation="Horizontal" VerticalAlignment="Center"
                            Margin="0,0,12,0"
                            Visibility="{Binding HasMatched, Converter={StaticResource BoolToVis}}">
                    <!-- Target mapped counter badge -->
                    <Border Background="#f8faf9" CornerRadius="6" BorderBrush="{StaticResource Hairline}" BorderThickness="1" Padding="8,4" Margin="0,0,12,0">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="Target: " Foreground="{StaticResource MutedText}" FontSize="11" />
                            <TextBlock Text="{Binding TargetMappedCount}" Foreground="#2d7d50" FontWeight="Bold" FontSize="11" />
                            <TextBlock Text=" mapped, " Foreground="{StaticResource MutedText}" FontSize="11" />
                            <TextBlock Text="{Binding TargetUnmappedCount}" Foreground="#8a6010" FontWeight="Bold" FontSize="11" />
                            <TextBlock Text=" unmapped" Foreground="{StaticResource MutedText}" FontSize="11" />
                        </StackPanel>
                    </Border>
                    <Border Background="{StaticResource AutoTint}" CornerRadius="4" Padding="7,2" Margin="0,0,5,0">
                        <TextBlock FontSize="11" FontWeight="SemiBold" Foreground="#2d7d50"
                                   Text="{Binding ExactCount, StringFormat={}exact {0}}"
                                   ToolTip="Header names matched exactly" />
                    </Border>
                    <Border Background="#eaf2ec" CornerRadius="4" Padding="7,2" Margin="0,0,5,0">
                        <TextBlock FontSize="11" FontWeight="SemiBold" Foreground="#336650"
                                   Text="{Binding AliasCount, StringFormat={}alias {0}}"
                                   ToolTip="Matched through a synonym group" />
                    </Border>
                    <Border Background="#e8ede9" CornerRadius="4" Padding="7,2" Margin="0,0,5,0">
                        <TextBlock FontSize="11" FontWeight="SemiBold" Foreground="#6e8078"
                                   Text="{Binding QualifiedCount, StringFormat={}qualified {0}}"
                                   ToolTip="Matched through a qualified rule" />
                    </Border>
                    <Border Background="{StaticResource WarnBg}" CornerRadius="4" Padding="7,2">
                        <TextBlock FontSize="11" FontWeight="SemiBold" Foreground="{StaticResource WarnText}"
                                   Text="{Binding FuzzyCount, StringFormat={}fuzzy {0}}"
                                   ToolTip="Fuzzy matches (90%+) — worth a glance; their headers are tinted amber" />
                    </Border>
                </StackPanel>
                <!-- Execute button -->
                <Button DockPanel.Dock="Right" Content="Execute ▸" Style="{StaticResource PrimaryButton}"
                        MinWidth="140" Margin="12,0,0,0" Command="{Binding DataContext.WriteCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                        ToolTip="Write every mapped, non-hidden column to the output copy" />
                <TextBlock TextWrapping="Wrap" VerticalAlignment="Center" FontSize="12">
                    <TextBlock.Style>
                        <Style TargetType="TextBlock">
                            <Setter Property="Foreground">
                                <Setter.Value>
                                    <SolidColorBrush Color="#1a2420" />
                                </Setter.Value>
                            </Setter>
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding DataContext.StatusFlash, RelativeSource={RelativeSource AncestorType=Window}}" Value="True">
                                    <DataTrigger.EnterActions>
                                        <BeginStoryboard x:Name="FlashTextStoryboard">
                                            <Storyboard RepeatBehavior="Forever">
                                                <ColorAnimation Storyboard.TargetProperty="Foreground.Color"
                                                                To="#ffffff" Duration="0:0:1.25" AutoReverse="True" />
                                            </Storyboard>
                                        </BeginStoryboard>
                                    </DataTrigger.EnterActions>
                                    <DataTrigger.ExitActions>
                                        <RemoveStoryboard BeginStoryboardName="FlashTextStoryboard" />
                                    </DataTrigger.ExitActions>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </TextBlock.Style>
                    <Run Text="{Binding DataContext.Status, Mode=OneWay, RelativeSource={RelativeSource AncestorType=Window}}" />
                    <Hyperlink Command="{Binding DataContext.OpenOutputFileCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                               ToolTip="{Binding DataContext.OutputFilePath, RelativeSource={RelativeSource AncestorType=Window}}"
                               FontSize="14" FontWeight="SemiBold">
                        <Hyperlink.Style>
                            <Style TargetType="Hyperlink">
                                <Setter Property="Foreground">
                                    <Setter.Value>
                                        <SolidColorBrush Color="#0F62B0" />
                                    </Setter.Value>
                                </Setter>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding DataContext.HasOutputFile, RelativeSource={RelativeSource AncestorType=Window}}" Value="False">
                                        <Setter Property="IsEnabled" Value="False" />
                                    </DataTrigger>
                                    <DataTrigger Binding="{Binding DataContext.StatusFlash, RelativeSource={RelativeSource AncestorType=Window}}" Value="True">
                                        <DataTrigger.EnterActions>
                                            <BeginStoryboard x:Name="FlashLinkStoryboard">
                                                <Storyboard RepeatBehavior="Forever">
                                                    <ColorAnimation Storyboard.TargetProperty="Foreground.Color"
                                                                    To="#99ccff" Duration="0:0:1.25" AutoReverse="True" />
                                                </Storyboard>
                                            </BeginStoryboard>
                                        </DataTrigger.EnterActions>
                                        <DataTrigger.ExitActions>
                                            <RemoveStoryboard BeginStoryboardName="FlashLinkStoryboard" />
                                        </DataTrigger.ExitActions>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Hyperlink.Style>
                        <Run Text="{Binding DataContext.OutputFilePath, Mode=OneWay, RelativeSource={RelativeSource AncestorType=Window}}" />
                    </Hyperlink>
                </TextBlock>
            </DockPanel>
        </Border>
    </Grid>
</UserControl>
