<UserControl x:Class="CelMap.App.ParametersView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:CelMap.App"
             mc:Ignorable="d" 
             d:DataContext="{d:DesignInstance local:ParametersViewModel}">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <!-- Header -->
        <Grid Grid.Row="0" Margin="0,0,0,14">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>
            <StackPanel Grid.Column="0" Margin="0,0,12,0">
                <TextBlock Text="Insurance Member Data Parameters" FontSize="20" FontWeight="SemiBold"
                           Foreground="{StaticResource InkText}" TextTrimming="CharacterEllipsis" />
                <TextBlock Text="Specify global parameters and cover rules to auto-fill member records."
                           Foreground="{StaticResource MutedText}" FontSize="12" Margin="0,2,0,0"
                           TextTrimming="CharacterEllipsis" />
            </StackPanel>
            <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                <TextBlock Text="Aa" FontSize="11" Foreground="{StaticResource MutedText}"
                           VerticalAlignment="Center" Margin="0,0,5,0" />
                <ComboBox Width="110" FontSize="11"
                          ItemsSource="{Binding DataContext.DensityOptions, RelativeSource={RelativeSource AncestorType=Window}}"
                          SelectedItem="{Binding DataContext.UiDensity, RelativeSource={RelativeSource AncestorType=Window}}"
                          ToolTip="Display size — Large for easier reading, Compact for more on screen" />
            </StackPanel>
        </Grid>

        <!-- Content Area (Scrollable) -->
        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" MinWidth="320" />
                    <ColumnDefinition Width="20" />
                    <ColumnDefinition Width="2*" MinWidth="480" />
                </Grid.ColumnDefinitions>

                <!-- Left Panel: General Parameters -->
                <Border Grid.Column="0" Style="{StaticResource Card}" VerticalAlignment="Top">
                    <StackPanel>
                        <TextBlock Text="GENERAL PARAMETERS" Style="{StaticResource SectionHeader}" />
                        
                        <StackPanel Margin="0,6,0,12">
                            <Label Content="Group ID (Required)" Target="{Binding ElementName=GroupIdInput}" />
                            <TextBox x:Name="GroupIdInput" Text="{Binding GroupIdText, UpdateSourceTrigger=PropertyChanged}" />
                            <TextBlock Text="Must be an integer representing the employer group" FontSize="11" Foreground="{StaticResource MutedText}" Margin="0,2,0,0" />
                        </StackPanel>

                        <StackPanel Margin="0,0,0,12">
                            <Label Content="Insurer ID (Required)" Target="{Binding ElementName=InsurerIdInput}" />
                            <TextBox x:Name="InsurerIdInput" Text="{Binding InsurerIdText, UpdateSourceTrigger=PropertyChanged}" />
                            <TextBlock Text="Defaults to 1" FontSize="11" Foreground="{StaticResource MutedText}" Margin="0,2,0,0" />
                        </StackPanel>

                        <StackPanel Margin="0,0,0,12">
                            <Label Content="Review Start Date" />
                            <DatePicker SelectedDate="{Binding ReviewStart}" SelectedDateFormat="Short" />
                        </StackPanel>

                        <StackPanel Margin="0,0,0,6">
                            <Label Content="Review End Date" />
                            <DatePicker SelectedDate="{Binding ReviewEnd}" SelectedDateFormat="Short" />
                            <TextBlock Text="Defaults to 1 year less 1 day from Start Date" FontSize="11" Foreground="{StaticResource MutedText}" Margin="0,2,0,0" />
                        </StackPanel>
                    </StackPanel>
                </Border>

                <!-- Right Panel: Cover Configuration & Category Specifics -->
                <Border Grid.Column="2" Style="{StaticResource Card}">
                    <DockPanel>
                        <!-- Default Cover Types Section -->
                        <StackPanel DockPanel.Dock="Top" Margin="0,0,0,16">
                            <TextBlock Text="DEFAULT COVER TYPES" Style="{StaticResource SectionHeader}" />
                            <TextBlock Text="Select default covers applicable to all members (unless overridden below):" FontSize="11" Foreground="{StaticResource MutedText}" Margin="0,0,0,8" />
                            <WrapPanel Orientation="Horizontal">
                                <CheckBox Content="GSC" IsChecked="{Binding DefaultCoverGSC}" Margin="0,0,24,6" VerticalContentAlignment="Center" />
                                <CheckBox Content="GL" IsChecked="{Binding DefaultCoverGL}" Margin="0,0,24,6" VerticalContentAlignment="Center" />
                                <CheckBox Content="TPD" IsChecked="{Binding DefaultCoverTPD}" Margin="0,0,24,6" VerticalContentAlignment="Center" />
                                <CheckBox Content="Trauma" IsChecked="{Binding DefaultCoverTrauma}" Margin="0,0,24,6" VerticalContentAlignment="Center" />
                                <CheckBox Content="GLTPD" IsChecked="{Binding DefaultCoverGLTPD}" Margin="0,0,24,6" VerticalContentAlignment="Center" />
                            </WrapPanel>
                        </StackPanel>

                        <Separator DockPanel.Dock="Top" Margin="0,0,0,12" Background="{StaticResource Hairline}" Height="1" />

                        <!-- Category Specific Cover Types Section -->
                        <DockPanel>
                            <StackPanel DockPanel.Dock="Top" Margin="0,0,0,8">
                                <TextBlock Text="CATEGORY SPECIFIC OVERRIDES (OPTIONAL)" Style="{StaticResource SectionHeader}" />
                                <TextBlock Text="Type in a category name (number/letter) to enable specific overrides:" FontSize="11" Foreground="{StaticResource MutedText}" />
                            </StackPanel>

                            <!-- Categories Grid -->
                            <DataGrid ItemsSource="{Binding CategoryOverrides}" AutoGenerateColumns="False" 
                                      CanUserAddRows="False" CanUserDeleteRows="False" CanUserReorderColumns="False" CanUserSortColumns="False"
                                      GridLinesVisibility="Horizontal" HeadersVisibility="Column" Background="Transparent" BorderThickness="0"
                                      RowBackground="Transparent" RowHeaderWidth="0" MaxHeight="220" VerticalAlignment="Top">
                                <DataGrid.Resources>
                                    <Style TargetType="DataGridColumnHeader">
                                        <Setter Property="Background" Value="#F2F5FA" />
                                        <Setter Property="BorderBrush" Value="{StaticResource GridLine}" />
                                        <Setter Property="BorderThickness" Value="0,0,0,1" />
                                        <Setter Property="Padding" Value="8,6" />
                                        <Setter Property="FontWeight" Value="SemiBold" />
                                        <Setter Property="Foreground" Value="{StaticResource InkText}" />
                                    </Style>
                                    <Style x:Key="CoverHeader" TargetType="DataGridColumnHeader"
                                           BasedOn="{StaticResource {x:Type DataGridColumnHeader}}">
                                        <Setter Property="HorizontalContentAlignment" Value="Center" />
                                    </Style>
                                    <Style TargetType="DataGridRow">
                                        <Setter Property="Background" Value="Transparent" />
                                        <Style.Triggers>
                                            <Trigger Property="IsSelected" Value="True">
                                                <Setter Property="Background" Value="#EDF3FC" />
                                            </Trigger>
                                        </Style.Triggers>
                                    </Style>
                                    <Style TargetType="DataGridCell">
                                        <Setter Property="Padding" Value="6,4" />
                                        <Setter Property="BorderThickness" Value="0" />
                                        <Setter Property="VerticalAlignment" Value="Center" />
                                        <Setter Property="FocusVisualStyle" Value="{x:Null}" />
                                        <Style.Triggers>
                                            <Trigger Property="IsSelected" Value="True">
                                                <Setter Property="Background" Value="Transparent" />
                                                <Setter Property="Foreground" Value="{StaticResource InkText}" />
                                            </Trigger>
                                        </Style.Triggers>
                                    </Style>
                                    <Style x:Key="CoverCheck" TargetType="CheckBox" BasedOn="{StaticResource {x:Type CheckBox}}">
                                        <Setter Property="IsEnabled" Value="{Binding IsCategoryNameValid}" />
                                        <Setter Property="HorizontalAlignment" Value="Center" />
                                        <Setter Property="VerticalAlignment" Value="Center" />
                                    </Style>
                                </DataGrid.Resources>
                                <DataGrid.Columns>
                                    <DataGridTextColumn Header="Category" Binding="{Binding CategoryName, UpdateSourceTrigger=PropertyChanged}" Width="100" FontWeight="SemiBold" />
                                    <DataGridCheckBoxColumn Header="GSC" Binding="{Binding Gsc, UpdateSourceTrigger=PropertyChanged}" Width="65"
                                                            HeaderStyle="{StaticResource CoverHeader}"
                                                            ElementStyle="{StaticResource CoverCheck}" EditingElementStyle="{StaticResource CoverCheck}" />
                                    <DataGridCheckBoxColumn Header="GL" Binding="{Binding Gl, UpdateSourceTrigger=PropertyChanged}" Width="65"
                                                            HeaderStyle="{StaticResource CoverHeader}"
                                                            ElementStyle="{StaticResource CoverCheck}" EditingElementStyle="{StaticResource CoverCheck}" />
                                    <DataGridCheckBoxColumn Header="TPD" Binding="{Binding Tpd, UpdateSourceTrigger=PropertyChanged}" Width="65"
                                                            HeaderStyle="{StaticResource CoverHeader}"
                                                            ElementStyle="{StaticResource CoverCheck}" EditingElementStyle="{StaticResource CoverCheck}" />
                                    <DataGridCheckBoxColumn Header="Trauma" Binding="{Binding Trauma, UpdateSourceTrigger=PropertyChanged}" Width="65"
                                                            HeaderStyle="{StaticResource CoverHeader}"
                                                            ElementStyle="{StaticResource CoverCheck}" EditingElementStyle="{StaticResource CoverCheck}" />
                                    <DataGridCheckBoxColumn Header="GLTPD" Binding="{Binding GlTpd, UpdateSourceTrigger=PropertyChanged}" Width="65"
                                                            HeaderStyle="{StaticResource CoverHeader}"
                                                            ElementStyle="{StaticResource CoverCheck}" EditingElementStyle="{StaticResource CoverCheck}" />
                                </DataGrid.Columns>
                            </DataGrid>
                        </DockPanel>
                    </DockPanel>
                </Border>
            </Grid>
        </ScrollViewer>

        <!-- Bottom Control Bar -->
        <Border Grid.Row="2" BorderBrush="{StaticResource Hairline}" BorderThickness="0,1,0,0" Padding="0,12,0,0" Margin="0,12,0,0">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                
                <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center">
                    <StackPanel Orientation="Horizontal"
                                Visibility="{Binding IsParametersValid, Converter={StaticResource BoolToVis}, ConverterParameter=invert}">
                        <TextBlock Text="⚠" Foreground="#DC2626" FontSize="12" Margin="0,0,6,0" />
                        <TextBlock Text="Enter a valid Group ID and Insurer ID to continue."
                                   Foreground="#DC2626" FontSize="12" />
                    </StackPanel>
                    <StackPanel Orientation="Horizontal"
                                Visibility="{Binding IsParametersValid, Converter={StaticResource BoolToVis}}">
                        <TextBlock Text="✓" Foreground="#16A34A" FontWeight="Bold" FontSize="12" Margin="0,0,6,0" />
                        <TextBlock Text="Parameters are valid — ready to proceed."
                                   Foreground="#16A34A" FontSize="12" />
                    </StackPanel>
                </StackPanel>
                
                <Button Grid.Column="1" Content="Continue to Setup →" Style="{StaticResource PrimaryButton}"
                        MinWidth="180" Command="{Binding DataContext.ContinueToSetupCommand, RelativeSource={RelativeSource AncestorType=Window}}" />
            </Grid>
        </Border>
    </Grid>
</UserControl>
