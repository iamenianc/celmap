<Application x:Class="CelMap.App.App"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:local="clr-namespace:CelMap.App"
             StartupUri="MainWindow.xaml">
    <Application.Resources>
        <!-- Palette -->
        <Color x:Key="AccentColor">#3d7a5a</Color>
        <SolidColorBrush x:Key="Accent" Color="{StaticResource AccentColor}" />
        <SolidColorBrush x:Key="AccentDark" Color="#336650" />
        <SolidColorBrush x:Key="PanelBg" Color="#ffffff" />
        <SolidColorBrush x:Key="WindowBg" Color="#f2f4f3" />
        <SolidColorBrush x:Key="TargetPanelBg" Color="#f8faf9" />
        <SolidColorBrush x:Key="ZebraBg" Color="#f8faf9" />
        <SolidColorBrush x:Key="Hairline" Color="#dde3df" />
        <SolidColorBrush x:Key="MutedText" Color="#6e8078" />
        <SolidColorBrush x:Key="InkText" Color="#1a2420" />
        <SolidColorBrush x:Key="LinkedBg" Color="#eaf2ec" />
        <SolidColorBrush x:Key="WarnBg" Color="#faf0d8" />
        <SolidColorBrush x:Key="WarnText" Color="#8a6010" />
        <SolidColorBrush x:Key="SelectBg" Color="#3d7a5a" />
        <SolidColorBrush x:Key="GridLine" Color="#c8d0cb" />
        <SolidColorBrush x:Key="HeaderCellBg" Color="#f8faf9" />
        <SolidColorBrush x:Key="AutoTint" Color="#daeade" />     <!-- auto-mapped slot -->
        <SolidColorBrush x:Key="ManualTint" Color="#eaf2ec" />   <!-- user-mapped slot -->
        <SolidColorBrush x:Key="DropZoneBg" Color="#f0f3f1" />

        <!-- Fixed column width for the Excel-like grids. Wide enough to show most headers in
             full on a maximised window; the rest truncate with a tooltip. -->
        <sys:Double x:Key="GridColWidth" xmlns:sys="clr-namespace:System;assembly=System.Runtime">140</sys:Double>

        <!-- Typography defaults -->
        <Style TargetType="{x:Type Control}">
            <Setter Property="FontFamily" Value="Segoe UI" />
        </Style>

        <Style x:Key="SectionHeader" TargetType="TextBlock">
            <Setter Property="FontSize" Value="12" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Foreground" Value="{StaticResource MutedText}" />
            <Setter Property="Margin" Value="0,0,0,6" />
        </Style>

        <Style x:Key="Card" TargetType="Border">
            <Setter Property="Background" Value="{StaticResource PanelBg}" />
            <Setter Property="BorderBrush" Value="{StaticResource Hairline}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="CornerRadius" Value="8" />
            <Setter Property="Padding" Value="14" />
        </Style>

        <!-- Primary button -->
        <Style x:Key="PrimaryButton" TargetType="Button">
            <Setter Property="Foreground" Value="White" />
            <Setter Property="Background" Value="{StaticResource Accent}" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="FontSize" Value="14" />
            <Setter Property="Padding" Value="18,8" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="b" Background="{TemplateBinding Background}"
                                CornerRadius="6" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="b" Property="Background" Value="{StaticResource AccentDark}" />
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="b" Property="Background" Value="#e8ede9" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Secondary (outline) button -->
        <Style x:Key="GhostButton" TargetType="Button">
            <Setter Property="Foreground" Value="{StaticResource InkText}" />
            <Setter Property="Background" Value="White" />
            <Setter Property="FontSize" Value="13" />
            <Setter Property="Padding" Value="12,6" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="b" Background="{TemplateBinding Background}"
                                BorderBrush="{StaticResource Hairline}" BorderThickness="1"
                                CornerRadius="6" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="b" Property="Background" Value="#f0f3f1" />
                                <Setter TargetName="b" Property="BorderBrush" Value="{StaticResource Accent}" />
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Opacity" Value="0.5" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Tertiary text-link button — for rare, demoted actions (e.g. "use a custom file").
             No border or fill; reads as a hyperlink that underlines on hover. -->
        <Style x:Key="LinkButton" TargetType="Button">
            <Setter Property="Foreground" Value="{StaticResource Accent}" />
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="FontSize" Value="11" />
            <Setter Property="Padding" Value="2,0" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="Transparent" Padding="{TemplateBinding Padding}">
                            <TextBlock x:Name="t" Text="{TemplateBinding Content}"
                                       Foreground="{TemplateBinding Foreground}" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="t" Property="TextDecorations" Value="Underline" />
                                <Setter Property="Foreground" Value="{StaticResource AccentDark}" />
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Opacity" Value="0.5" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style TargetType="Label">
            <Setter Property="Padding" Value="0,0,0,2" />
            <Setter Property="Foreground" Value="{StaticResource MutedText}" />
            <Setter Property="FontSize" Value="12" />
        </Style>
        <Style TargetType="TextBox">
            <Setter Property="VerticalContentAlignment" Value="Center" />
            <Setter Property="Padding" Value="6,4" />
            <Setter Property="BorderBrush" Value="{StaticResource Hairline}" />
        </Style>
        <Style TargetType="ComboBox">
            <Setter Property="Padding" Value="6,4" />
        </Style>

        <!-- Excel-like grid cells — readable font, single line, truncated with a tooltip.
             Compact: tighter padding buys ~4 extra visible rows per grid. -->
        <Style x:Key="GridDataCell" TargetType="TextBlock">
            <Setter Property="FontSize" Value="12" />
            <Setter Property="Foreground" Value="{StaticResource InkText}" />
            <Setter Property="Padding" Value="6,2" />
            <Setter Property="Height" Value="20" />
            <Setter Property="VerticalAlignment" Value="Center" />
            <Setter Property="TextTrimming" Value="CharacterEllipsis" />
        </Style>

        <!-- Wrapper for one data cell in the Excel-like grids: hairline row separator plus
             zebra banding so the eye can track a record across many columns. Requires
             AlternationCount=2 on the owning ItemsControl. -->
        <Style x:Key="ZebraRowCell" TargetType="Border">
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderBrush" Value="#e8ede9" />
            <Setter Property="BorderThickness" Value="0,0,0,1" />
            <Style.Triggers>
                <DataTrigger Binding="{Binding Path=(ItemsControl.AlternationIndex),
                                       RelativeSource={RelativeSource AncestorType=ContentPresenter}}" Value="1">
                    <Setter Property="Background" Value="{StaticResource ZebraBg}" />
                </DataTrigger>
            </Style.Triggers>
        </Style>

        <!-- Header cell at the top of a grid column — tall enough for two wrapped lines so
             long insurance column names stay readable instead of truncating. -->
        <Style x:Key="GridHeaderCell" TargetType="Border">
            <Setter Property="Background" Value="{StaticResource HeaderCellBg}" />
            <Setter Property="BorderBrush" Value="{StaticResource GridLine}" />
            <Setter Property="BorderThickness" Value="0,0,1,1" />
            <Setter Property="Padding" Value="6,4" />
            <Setter Property="Height" Value="40" />
        </Style>

        <!-- File drop-zone on the setup screen — compact -->
        <Style x:Key="DropZone" TargetType="Border">
            <Setter Property="Background" Value="{StaticResource DropZoneBg}" />
            <Setter Property="BorderBrush" Value="{StaticResource Hairline}" />
            <Setter Property="BorderThickness" Value="2" />
            <Setter Property="CornerRadius" Value="8" />
            <Setter Property="Padding" Value="12" />
            <Setter Property="MinHeight" Value="64" />
        </Style>

        <local:KindToBrushConverter x:Key="KindToBrush" />
        <local:BoolToVisibilityConverter x:Key="BoolToVis" />
        <local:StringMatchToVisibilityConverter x:Key="StateToVis" />
        <local:ExcludeCurrentItemConverter x:Key="ExcludeCurrentItem" />
        <local:AvailableSourcesForRowConverter x:Key="AvailableSourcesForRow" />
    </Application.Resources>
</Application>
