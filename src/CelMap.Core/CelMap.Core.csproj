<Project Sdk="Microsoft.NET.Sdk">

  <PropertyGroup>
    <TargetFramework>net10.0</TargetFramework>
    <ImplicitUsings>enable</ImplicitUsings>
    <Nullable>enable</Nullable>
  </PropertyGroup>

  <ItemGroup>
    <PackageReference Include="ClosedXML" Version="0.105.0" />
    <PackageReference Include="FuzzySharp" Version="2.0.2" />
  </ItemGroup>

  <ItemGroup>
    <!-- Default alias/synonym + qualified-rule files; copied next to consuming hosts
         (and projects that reference this library) so they load by default. -->
    <Content Include="synonyms.json" CopyToOutputDirectory="PreserveNewest" />
    <Content Include="qualified_rules.json" CopyToOutputDirectory="PreserveNewest" />
  </ItemGroup>

</Project>
